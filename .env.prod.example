# =========================================
# SealAI – Production Template (.env.prod.example)
# =========================================
# Copy this file to .env.prod on the VPS and replace every placeholder with
# real production values before running ./ops/up-prod.sh.
# .env.prod is intentionally gitignored and must never be committed.

# Immutable release refs
# Prefer tag@digest for auditability and rollback clarity.
BACKEND_IMAGE=ghcr.io/jungt72/sealai-backend:vYYYY.MM.DD-N@sha256:<REPLACE_ME>
BACKEND_PULL_POLICY=always
KEYCLOAK_IMAGE=ghcr.io/jungt72/sealai-keycloak:vYYYY.MM.DD-N@sha256:<REPLACE_ME>
# Optional: only used if the frontend-container profile is ever enabled.
FRONTEND_IMAGE=ghcr.io/jungt72/sealai-frontend:vYYYY.MM.DD-N@sha256:<REPLACE_ME>

# Postgres
POSTGRES_PASSWORD=<REPLACE_ME>
DATABASE_URL=postgresql+psycopg://sealai:${POSTGRES_PASSWORD}@postgres:5432/sealai

# Shared Redis service (not consumed by V2 or marketing)
REDIS_PASSWORD=<REPLACE_ME>
REDIS_MAXMEMORY=1024mb
APP_ENV=production

# Keycloak DB. Bootstrap/recovery admin credentials must never persist in the
# runtime env; use the one-shot recovery procedure in docs/keycloak-upgrade.md.
# The container receives POSTGRES_PASSWORD as KCRAW_DB_PASSWORD; do not define
# a second Keycloak DB password alias here.

# Keycloak Hostname + OIDC
KC_HOSTNAME=https://sealingai.com
# Keep `test` only while the owner explicitly operates the public instance as a
# test system. `production` requires configured Keycloak SMTP and privileged MFA.
KEYCLOAK_SECURITY_PROFILE=production
KEYCLOAK_ISSUER=https://sealingai.com/realms/sealAI
KEYCLOAK_JWKS_URL=https://sealingai.com/realms/sealAI/protocol/openid-connect/certs
KEYCLOAK_EXPECTED_AZP=nextauth
KEYCLOAK_CLIENT_ID=nextauth
KEYCLOAK_CLIENT_SECRET=<REPLACE_ME>

# NextAuth
NEXTAUTH_SECRET=<REPLACE_ME>
NEXTAUTH_URL=https://sealingai.com

# Frontend / API
NEXT_PUBLIC_API_BASE=https://sealingai.com
NEXT_PUBLIC_SITE_URL=https://sealingai.com
NEXT_PUBLIC_ANALYTICS_ENABLED=false
NEXT_PUBLIC_GTM_ID=
NEXT_PUBLIC_GA_MEASUREMENT_ID=
NEXT_PUBLIC_GOOGLE_CONSENT_DEFAULT=denied
NEXT_PUBLIC_RYBBIT_ENABLED=false
NEXT_PUBLIC_RYBBIT_SITE_ID=
NEXT_PUBLIC_RYBBIT_SCRIPT_SRC=https://analytics.sealingai.com/api/script.js
NEXT_PUBLIC_RYBBIT_DASHBOARD_URL=
SITE_URL=https://sealingai.com
SEALAI_BACKEND_ORIGIN=http://127.0.0.1:8000
# Next.js binds to Docker's host bridge so nginx in Docker can proxy it
# without exposing the frontend directly on every public interface.
FRONTEND_BIND_HOST=172.17.0.1

# OpenAI
OPENAI_API_KEY=<REPLACE_ME>
MISTRAL_API_KEY=<REPLACE_ME>

# sealingAI V2 deterministic-first model policy
SEALAI_V2_PROVIDER=mistral
SEALAI_V2_L1_PROVIDER=openai
SEALAI_V2_L1_MODEL=gpt-5.5
SEALAI_V2_STANDARD_PROVIDER=mistral
SEALAI_V2_STANDARD_MODEL=mistral-small-2603
SEALAI_V2_VERIFIER_PROVIDER=mistral
SEALAI_V2_VERIFIER_MODEL=mistral-small-2603
SEALAI_V2_HELPER_PROVIDER=mistral
SEALAI_V2_HELPER_MODEL=mistral-small-2603
SEALAI_V2_JUDGE_PROVIDER=openai
SEALAI_V2_JUDGE_MODEL=gpt-5.4-mini-2026-03-17
SEALAI_V2_RETRIEVER_BACKEND=qdrant
SEALAI_V2_QDRANT_COLLECTION=sealai_v2_knowledge_local_minilm_v1
SEALAI_V2_MEMORY_QDRANT_COLLECTION=sealai_v2_memory_local_minilm_v1
SEALAI_V2_EMBED_PROVIDER=fastembed
SEALAI_V2_EMBED_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
SEALAI_V2_EMBED_CACHE_DIR=/app/models
SEALAI_V2_EMBED_QUERY_PREFIX=
SEALAI_V2_EMBED_PASSAGE_PREFIX=
SEALAI_V2_EVAL_JUDGE_REASONING_EFFORT=low
SEALAI_V2_EVAL_JUDGE_MAX_OUTPUT_TOKENS=1024
SEALAI_V2_EXECUTION_POLICY_ENABLED=true
SEALAI_V2_STRUCTURED_ANSWER_ENABLED=true
# Keep disabled until a release binds the complete active authority set to a canonical digest.
# Enabling without SEALAI_V2_KNOWLEDGE_AUTHORITY_EPOCH fails closed; no example epoch is provided.
SEALAI_V2_EXACT_ANSWER_CACHE_ENABLED=false
SEALAI_V2_ROUTE_OPTIMIZATION_ENABLED=true
SEALAI_V2_ROUTE_PROMPT_FAMILIES_ENABLED=true
SEALAI_V2_SUPPRESS_CALC_FOR_NON_KERNEL_ROUTES_ENABLED=true
SEALAI_V2_BASELINE_HARDENING_ENABLED=true
SEALAI_V2_COVERAGE_GATE_ENABLED=true
SEALAI_V2_RESPONSE_CONTRACT_ENABLED=true
SEALAI_V2_RESPONSE_CONTRACT_GENERAL_GUARD_ENABLED=true
SEALAI_V2_KNOWLEDGE_MODE_ENABLED=false
SEALAI_V2_KNOWLEDGE_REVIEW_ENABLED=false
SEALAI_V2_COMPATIBILITY_MATRIX_ENABLED=false
SEALAI_V2_CASE_DECISION_RECORDS_ENABLED=false
SEALAI_V2_CAPABILITY_PROFILES_ENABLED=false
SEALAI_V2_MANUFACTURER_FIT_ENABLED=false
SEALAI_V2_MANUFACTURER_HANDOFF_ENABLED=false
SEALAI_V2_AUTH_CAPABILITY_REVIEWER_ROLE=capability_reviewer
SEALAI_V2_AUTH_KNOWLEDGE_REVIEWER_ROLE=knowledge_reviewer
SEALAI_V2_AUTH_DECISION_REVIEWER_ROLE=decision_reviewer

# LangSmith tracing
# Prefer LANGSMITH_*; LANGCHAIN_* names are kept for older LangChain integrations.
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=<REPLACE_WITH_LANGSMITH_API_KEY_OR_EMPTY>
LANGSMITH_PROJECT=sealai-production
LANGSMITH_ENDPOINT=
SEALAI_TRACE_HASH_SALT=<REPLACE_WITH_STABLE_SECRET_SALT>
LANGSMITH_CAPTURE_LLM_CONTENT=false
LANGSMITH_TRACE_LANGGRAPH_CHILDREN=false
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=<REPLACE_WITH_LANGSMITH_API_KEY_OR_EMPTY>
LANGCHAIN_PROJECT=sealai-production
LANGCHAIN_ENDPOINT=

# CORS / Auth
ALLOWED_ORIGIN=https://sealingai.com,https://www.sealingai.com
ALLOW_WS_ORIGIN_ANY=0
ALLOW_WS_ORIGIN_EMPTY=0
AUTH_URL=https://sealingai.com
AUTH_SECRET=<REPLACE_ME>
AUTH_TRUST_HOST=true
AUTH_DEBUG=1
NEXTAUTH_DEBUG=1

QDRANT_COLLECTION=sealai_knowledge_v3
