# =========================================
# SealAI – Production Template (.env.prod.example)
# =========================================
# Copy this file to .env.prod on the VPS and replace every placeholder with
# real production values before running ./ops/up-prod.sh.
# .env.prod is intentionally gitignored and must never be committed.

# Immutable release refs
# Prefer tag@digest for auditability and rollback clarity.
BACKEND_IMAGE=ghcr.io/jungt72/sealai-backend:vYYYY.MM.DD-N@sha256:<REPLACE_ME>
BACKEND_PULL_POLICY=always
BACKEND_V2_IMAGE=ghcr.io/jungt72/sealai-backend-v2:vYYYY.MM.DD-N@sha256:<REPLACE_ME>
KEYCLOAK_IMAGE=ghcr.io/jungt72/sealai-keycloak:vYYYY.MM.DD-N@sha256:<REPLACE_ME>
# Optional: only used if the frontend-container profile is ever enabled.
FRONTEND_IMAGE=ghcr.io/jungt72/sealai-frontend:vYYYY.MM.DD-N@sha256:<REPLACE_ME>
NGINX_IMAGE=docker.io/library/nginx:<APPROVED_TAG>@sha256:<REPLACE_ME>
POSTGRES_IMAGE=docker.io/library/postgres:<APPROVED_TAG>@sha256:<REPLACE_ME>
REDIS_IMAGE=docker.io/redis/redis-stack-server:<APPROVED_TAG>@sha256:<REPLACE_ME>
QDRANT_IMAGE=docker.io/qdrant/qdrant:<APPROVED_TAG>@sha256:<REPLACE_ME>
GOTENBERG_IMAGE=docker.io/gotenberg/gotenberg:<APPROVED_TAG>@sha256:<REPLACE_ME>
TIKA_IMAGE=docker.io/apache/tika:<APPROVED_TAG>@sha256:<REPLACE_ME>

# Required but intentionally unresolved until the Gate-08 bounded-load
# rehearsal. Do not copy guessed resource limits into production.
POSTGRES_MEMORY_LIMIT=<SET_FROM_LOAD_PROFILE>
POSTGRES_CPU_LIMIT=<SET_FROM_LOAD_PROFILE>
POSTGRES_PIDS_LIMIT=<SET_FROM_LOAD_PROFILE>
REDIS_MEMORY_LIMIT=<SET_FROM_LOAD_PROFILE>
REDIS_CPU_LIMIT=<SET_FROM_LOAD_PROFILE>
REDIS_PIDS_LIMIT=<SET_FROM_LOAD_PROFILE>
QDRANT_MEMORY_LIMIT=<SET_FROM_LOAD_PROFILE>
QDRANT_CPU_LIMIT=<SET_FROM_LOAD_PROFILE>
QDRANT_PIDS_LIMIT=<SET_FROM_LOAD_PROFILE>
GOTENBERG_MEMORY_LIMIT=<SET_FROM_LOAD_PROFILE>
GOTENBERG_CPU_LIMIT=<SET_FROM_LOAD_PROFILE>
GOTENBERG_PIDS_LIMIT=<SET_FROM_LOAD_PROFILE>
TIKA_MEMORY_LIMIT=<SET_FROM_LOAD_PROFILE>
TIKA_CPU_LIMIT=<SET_FROM_LOAD_PROFILE>
TIKA_PIDS_LIMIT=<SET_FROM_LOAD_PROFILE>
PROMETHEUS_MEMORY_LIMIT=<SET_FROM_LOAD_PROFILE>
PROMETHEUS_CPU_LIMIT=<SET_FROM_LOAD_PROFILE>
PROMETHEUS_PIDS_LIMIT=<SET_FROM_LOAD_PROFILE>
GRAFANA_MEMORY_LIMIT=<SET_FROM_LOAD_PROFILE>
GRAFANA_CPU_LIMIT=<SET_FROM_LOAD_PROFILE>
GRAFANA_PIDS_LIMIT=<SET_FROM_LOAD_PROFILE>
ALERTMANAGER_MEMORY_LIMIT=<SET_FROM_LOAD_PROFILE>
ALERTMANAGER_CPU_LIMIT=<SET_FROM_LOAD_PROFILE>
ALERTMANAGER_PIDS_LIMIT=<SET_FROM_LOAD_PROFILE>
BLACKBOX_EXPORTER_MEMORY_LIMIT=<SET_FROM_LOAD_PROFILE>
BLACKBOX_EXPORTER_CPU_LIMIT=<SET_FROM_LOAD_PROFILE>
BLACKBOX_EXPORTER_PIDS_LIMIT=<SET_FROM_LOAD_PROFILE>
NODE_EXPORTER_MEMORY_LIMIT=<SET_FROM_LOAD_PROFILE>
NODE_EXPORTER_CPU_LIMIT=<SET_FROM_LOAD_PROFILE>
NODE_EXPORTER_PIDS_LIMIT=<SET_FROM_LOAD_PROFILE>
CADVISOR_MEMORY_LIMIT=<SET_FROM_LOAD_PROFILE>
CADVISOR_CPU_LIMIT=<SET_FROM_LOAD_PROFILE>
CADVISOR_PIDS_LIMIT=<SET_FROM_LOAD_PROFILE>
POSTGRES_EXPORTER_MEMORY_LIMIT=<SET_FROM_LOAD_PROFILE>
POSTGRES_EXPORTER_CPU_LIMIT=<SET_FROM_LOAD_PROFILE>
POSTGRES_EXPORTER_PIDS_LIMIT=<SET_FROM_LOAD_PROFILE>
REDIS_EXPORTER_MEMORY_LIMIT=<SET_FROM_LOAD_PROFILE>
REDIS_EXPORTER_CPU_LIMIT=<SET_FROM_LOAD_PROFILE>
REDIS_EXPORTER_PIDS_LIMIT=<SET_FROM_LOAD_PROFILE>
FRONTEND_MEMORY_LIMIT=<SET_FROM_LOAD_PROFILE>
FRONTEND_CPU_LIMIT=<SET_FROM_LOAD_PROFILE>
FRONTEND_PIDS_LIMIT=<SET_FROM_LOAD_PROFILE>
KEYCLOAK_MEMORY_LIMIT=<SET_FROM_LOAD_PROFILE>
KEYCLOAK_CPU_LIMIT=<SET_FROM_LOAD_PROFILE>
KEYCLOAK_PIDS_LIMIT=<SET_FROM_LOAD_PROFILE>
NGINX_MEMORY_LIMIT=<SET_FROM_LOAD_PROFILE>
NGINX_CPU_LIMIT=<SET_FROM_LOAD_PROFILE>
NGINX_PIDS_LIMIT=<SET_FROM_LOAD_PROFILE>
BACKEND_V2_MEMORY_LIMIT=<SET_FROM_LOAD_PROFILE>
BACKEND_V2_CPU_LIMIT=<SET_FROM_LOAD_PROFILE>
BACKEND_V2_PIDS_LIMIT=<SET_FROM_LOAD_PROFILE>
BACKEND_V2_WORKER_MEMORY_LIMIT=<SET_FROM_LOAD_PROFILE>
BACKEND_V2_WORKER_CPU_LIMIT=<SET_FROM_LOAD_PROFILE>
BACKEND_V2_WORKER_PIDS_LIMIT=<SET_FROM_LOAD_PROFILE>
CONTAINER_LOG_MAX_SIZE=10m
CONTAINER_LOG_MAX_FILES=5
STRAPI_POSTGRES_NETWORK_NAME=<SET_DURING_GATE_05>

# Postgres
POSTGRES_PASSWORD=<REPLACE_ME>
DATABASE_URL=postgresql+psycopg://sealai:${POSTGRES_PASSWORD}@postgres:5432/sealai

# Shared Redis service (not consumed by V2 or marketing)
REDIS_PASSWORD=<REPLACE_ME>
REDIS_MAXMEMORY=1024mb
APP_ENV=production

# Qdrant application-write and monitoring-read identities. Use distinct random
# values; the read-only value becomes a Docker secret for Prometheus.
QDRANT_API_KEY=<REPLACE_ME>
QDRANT_READ_ONLY_API_KEY=<REPLACE_ME>

# Keycloak and V2 use distinct least-privilege Postgres roles. Bootstrap or
# recovery-admin credentials must never persist in this runtime file.
KC_DB_NAME=keycloak
KC_DB_USERNAME=<REPLACE_WITH_DEDICATED_KEYCLOAK_DB_ROLE>
KC_DB_PASSWORD=<REPLACE_ME>
SEALAI_V2_DB_USER=<REPLACE_WITH_DEDICATED_V2_DB_ROLE>
SEALAI_V2_DB_PASSWORD=<REPLACE_ME>

# Keycloak Hostname + OIDC
KC_HOSTNAME=https://sealingai.com
# Keep `test` only while the owner explicitly operates the public instance as a
# test system. `production` requires configured Keycloak SMTP and privileged MFA.
KEYCLOAK_SECURITY_PROFILE=production
KEYCLOAK_ISSUER=https://sealingai.com/realms/sealAI
KEYCLOAK_JWKS_URL=https://sealingai.com/realms/sealAI/protocol/openid-connect/certs
KEYCLOAK_EXPECTED_AZP=nextauth
KEYCLOAK_CLIENT_ID=nextauth
KEYCLOAK_CLIENT_SECRET=<REPLACE_ME>

# NextAuth
NEXTAUTH_SECRET=<REPLACE_ME>
NEXTAUTH_URL=https://sealingai.com

# Frontend / API
NEXT_PUBLIC_API_BASE=https://sealingai.com
NEXT_PUBLIC_SITE_URL=https://sealingai.com
NEXT_PUBLIC_ANALYTICS_ENABLED=false
NEXT_PUBLIC_GTM_ID=
NEXT_PUBLIC_GA_MEASUREMENT_ID=
NEXT_PUBLIC_GOOGLE_CONSENT_DEFAULT=denied
NEXT_PUBLIC_RYBBIT_ENABLED=false
NEXT_PUBLIC_RYBBIT_SITE_ID=
NEXT_PUBLIC_RYBBIT_SCRIPT_SRC=https://analytics.sealingai.com/api/script.js
NEXT_PUBLIC_RYBBIT_DASHBOARD_URL=
SITE_URL=https://sealingai.com
SEALAI_BACKEND_ORIGIN=http://127.0.0.1:8000
# Next.js binds to Docker's host bridge so nginx in Docker can proxy it
# without exposing the frontend directly on every public interface.
FRONTEND_BIND_HOST=172.17.0.1

# OpenAI
OPENAI_API_KEY=<REPLACE_ME>
MISTRAL_API_KEY=<REPLACE_ME>

# Internal observability graph. Every image reference must be resolved to an
# approved immutable digest before GATE-08; tag-only references are rejected.
ALERTMANAGER_IMAGE=prom/alertmanager:v0.31.1@sha256:<REPLACE_ME>
BLACKBOX_EXPORTER_IMAGE=prom/blackbox-exporter:<APPROVED_TAG>@sha256:<REPLACE_ME>
NODE_EXPORTER_IMAGE=prom/node-exporter:<APPROVED_TAG>@sha256:<REPLACE_ME>
CADVISOR_IMAGE=gcr.io/cadvisor/cadvisor:<APPROVED_TAG>@sha256:<REPLACE_ME>
POSTGRES_EXPORTER_IMAGE=quay.io/prometheuscommunity/postgres-exporter:<APPROVED_TAG>@sha256:<REPLACE_ME>
REDIS_EXPORTER_IMAGE=oliver006/redis_exporter:<APPROVED_TAG>@sha256:<REPLACE_ME>
PROMETHEUS_RETENTION_TIME=30d
PROMETHEUS_RETENTION_SIZE=8GB
ALERTMANAGER_RETENTION_TIME=120h
DOCKER_LOG_MAX_SIZE=10m
DOCKER_LOG_MAX_FILE=3
NODE_EXPORTER_TEXTFILE_DIR=/var/lib/sealai/node-exporter/textfile
GRAFANA_ADMIN_PASSWORD=<REPLACE_ME>
# Scoped monitoring identities provisioned before deployment. The Postgres role
# receives pg_monitor plus CONNECT only; the Redis ACL receives read/INFO only.
POSTGRES_EXPORTER_DSN=postgresql://sealai_monitor:<REPLACE_ME>@postgres:5432/postgres?sslmode=disable
REDIS_EXPORTER_USER=sealai_monitor
REDIS_EXPORTER_PASSWORD=<REPLACE_ME>
# Two independently owned endpoints: the watchdog endpoint must alarm on a
# missed heartbeat and must not depend on this VPS.
ALERTMANAGER_WEBHOOK_URL=<REPLACE_WITH_HTTPS_EXTERNAL_RECEIVER>
ALERTMANAGER_WATCHDOG_URL=<REPLACE_WITH_INDEPENDENT_HTTPS_DEADMAN_RECEIVER>

# sealingAI V2 deterministic-first model policy
SEALAI_V2_PROVIDER=mistral
SEALAI_V2_L1_PROVIDER=openai
SEALAI_V2_L1_MODEL=gpt-5.5
SEALAI_V2_STANDARD_PROVIDER=mistral
SEALAI_V2_STANDARD_MODEL=mistral-small-2603
SEALAI_V2_VERIFIER_PROVIDER=mistral
SEALAI_V2_VERIFIER_MODEL=mistral-small-2603
SEALAI_V2_HELPER_PROVIDER=mistral
SEALAI_V2_HELPER_MODEL=mistral-small-2603
SEALAI_V2_JUDGE_PROVIDER=openai
SEALAI_V2_JUDGE_MODEL=gpt-5.4-mini-2026-03-17
SEALAI_V2_RETRIEVER_BACKEND=qdrant
SEALAI_V2_QDRANT_COLLECTION=sealai_v2_knowledge_local_minilm_v1
SEALAI_V2_MEMORY_QDRANT_COLLECTION=sealai_v2_memory_local_minilm_v1
SEALAI_V2_EMBED_PROVIDER=fastembed
SEALAI_V2_EMBED_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
SEALAI_V2_EMBED_CACHE_DIR=/app/models
SEALAI_V2_EMBED_QUERY_PREFIX=
SEALAI_V2_EMBED_PASSAGE_PREFIX=
SEALAI_V2_EVAL_JUDGE_REASONING_EFFORT=low
SEALAI_V2_EVAL_JUDGE_MAX_OUTPUT_TOKENS=1024
SEALAI_V2_EXECUTION_POLICY_ENABLED=true
SEALAI_V2_STRUCTURED_ANSWER_ENABLED=true
# Keep disabled until a release binds the complete active authority set to a canonical digest.
# Enabling without SEALAI_V2_KNOWLEDGE_AUTHORITY_EPOCH fails closed; no example epoch is provided.
SEALAI_V2_EXACT_ANSWER_CACHE_ENABLED=false
SEALAI_V2_ROUTE_OPTIMIZATION_ENABLED=true
SEALAI_V2_ROUTE_PROMPT_FAMILIES_ENABLED=true
SEALAI_V2_SUPPRESS_CALC_FOR_NON_KERNEL_ROUTES_ENABLED=true
SEALAI_V2_BASELINE_HARDENING_ENABLED=true
SEALAI_V2_COVERAGE_GATE_ENABLED=true
SEALAI_V2_RESPONSE_CONTRACT_ENABLED=true
SEALAI_V2_RESPONSE_CONTRACT_GENERAL_GUARD_ENABLED=true
SEALAI_V2_KNOWLEDGE_MODE_ENABLED=false
SEALAI_V2_KNOWLEDGE_REVIEW_ENABLED=false
SEALAI_V2_COMPATIBILITY_MATRIX_ENABLED=false
SEALAI_V2_CASE_DECISION_RECORDS_ENABLED=false
SEALAI_V2_CAPABILITY_PROFILES_ENABLED=false
SEALAI_V2_MANUFACTURER_FIT_ENABLED=false
SEALAI_V2_MANUFACTURER_HANDOFF_ENABLED=false
SEALAI_V2_AUTH_CAPABILITY_REVIEWER_ROLE=capability_reviewer
SEALAI_V2_AUTH_KNOWLEDGE_REVIEWER_ROLE=knowledge_reviewer
SEALAI_V2_AUTH_DECISION_REVIEWER_ROLE=decision_reviewer
SEALAI_V2_TELEMETRY_SAMPLE_RATE=0.10

# AUTH-001/002 secure baseline. Provider work remains disabled until GATE-06/GATE-07 and a reviewed
# worst-case cost contract supply a real sha256 digest; do not insert a placeholder digest.
SEALAI_V2_AUTH_JWKS_TTL_S=300
SEALAI_V2_AUTH_JWKS_MAX_TTL_S=600
SEALAI_V2_AUTH_JWKS_UNKNOWN_KID_REFRESH_INTERVAL_S=5
SEALAI_V2_AUTH_JWKS_NEGATIVE_KID_TTL_S=30
SEALAI_V2_AUTH_JWKS_MAX_NEGATIVE_KIDS=256
SEALAI_V2_AUTH_MAX_TOKEN_AGE_S=300
SEALAI_V2_AUTH_CLOCK_SKEW_S=30
SEALAI_V2_PROVIDER_REQUESTS_ENABLED=false
SEALAI_V2_PROVIDER_SUBJECT_REQUESTS_PER_MINUTE=6
SEALAI_V2_PROVIDER_TENANT_REQUESTS_PER_MINUTE=30
SEALAI_V2_PROVIDER_SUBJECT_REQUESTS_PER_DAY=100
SEALAI_V2_PROVIDER_TENANT_REQUESTS_PER_DAY=1000
SEALAI_V2_PROVIDER_TENANT_REQUESTS_PER_MONTH=20000
SEALAI_V2_PROVIDER_SUBJECT_MAX_CONCURRENT=2
SEALAI_V2_PROVIDER_TENANT_MAX_CONCURRENT=10
SEALAI_V2_PROVIDER_REQUEST_LEASE_S=300
SEALAI_V2_PROVIDER_REQUEST_RESERVATION_MICROS=250000
SEALAI_V2_PROVIDER_DAILY_BUDGET_MICROS=10000000
SEALAI_V2_PROVIDER_MONTHLY_BUDGET_MICROS=100000000
SEALAI_V2_PROVIDER_BUDGET_CONTRACT_SHA256=
SEALAI_V2_API_MAX_REQUEST_BODY_BYTES=131072

# LangSmith tracing
# Prefer LANGSMITH_*; LANGCHAIN_* names are kept for older LangChain integrations.
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=<REPLACE_WITH_LANGSMITH_API_KEY_OR_EMPTY>
LANGSMITH_PROJECT=sealai-production
LANGSMITH_ENDPOINT=
SEALAI_TRACE_HASH_SALT=<REPLACE_WITH_STABLE_SECRET_SALT>
LANGSMITH_CAPTURE_LLM_CONTENT=false
LANGSMITH_TRACE_LANGGRAPH_CHILDREN=false
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=<REPLACE_WITH_LANGSMITH_API_KEY_OR_EMPTY>
LANGCHAIN_PROJECT=sealai-production
LANGCHAIN_ENDPOINT=

# CORS / Auth
ALLOWED_ORIGIN=https://sealingai.com,https://www.sealingai.com
ALLOW_WS_ORIGIN_ANY=0
ALLOW_WS_ORIGIN_EMPTY=0
AUTH_URL=https://sealingai.com
AUTH_SECRET=<REPLACE_ME>
AUTH_TRUST_HOST=true
AUTH_DEBUG=1
NEXTAUTH_DEBUG=1

QDRANT_COLLECTION=sealai_knowledge_v3
