{
  "name": "sealai-frontend-v2",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Clean V2 client — minimal SPA projecting over /api/v2. Imports nothing from V1 (frontend/).",
  "scripts": {
    "dev": "vite",
    "build": "npm run check:boundary && npm run check:terminology && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "check:boundary": "node scripts/check-no-v1-imports.mjs",
    "check:terminology": "node scripts/check-terminology.mjs",
    "verify": "npm run check:boundary && npm run check:terminology && npm run typecheck && npm run test && npm run build"
  },
  "dependencies": {
    "jspdf": "^4.2.1",
    "katex": "0.18.1",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-markdown": "10.1.0",
    "rehype-katex": "7.0.1",
    "remark-gfm": "4.0.1",
    "remark-math": "6.0.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@types/node": "^26.1.1",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "6.0.3",
    "jsdom": "29.1.1",
    "typescript": "7.0.2",
    "vite": "8.1.5",
    "vitest": "4.1.10"
  }
}
