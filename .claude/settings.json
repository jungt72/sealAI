{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "//": "PROPOSED — review, then `mv .claude/settings.json.proposed .claude/settings.json` and restart the session to activate the hooks. Merges the existing project permissions with the governance hooks + permission gates.",
  "permissions": {
    "defaultMode": "plan",
    "disableBypassPermissionsMode": "disable",
    "allow": [
      "Bash(pwd:*)",
      "Bash(ls:*)",
      "Bash(find:*)",
      "Bash(grep:*)",
      "Bash(rg:*)",
      "Bash(cat:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(wc:*)",
      "Bash(awk:*)",
      "Bash(sed -n:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git rev-parse:*)",
      "Bash(git branch:*)",
      "Bash(git show:*)",
      "Bash(git ls-files:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git switch:*)",
      "Bash(git switch -c:*)",
      "Bash(git checkout -b:*)",
      "Bash(git push:*)",
      "Bash(git pull --ff-only:*)",
      "Bash(gh pr create:*)",
      "Bash(gh pr view:*)",
      "Bash(gh pr checks:*)",
      "Bash(gh pr merge:*)",
      "Bash(python:*)",
      "Bash(python3:*)",
      "Bash(.venv/bin/python:*)",
      "Bash(pytest:*)",
      "Bash(npm run:*)",
      "Bash(npx tsc:*)",
      "Bash(node:*)",
      "Bash(touch .claude/.gate-logs/:*)",
      "Bash(docker inspect backend:*)",
      "Bash(docker compose ps:*)",
      "Bash(docker compose logs:*)"
    ],
    "ask": [
      "Bash(git checkout:*)",
      "Bash(git merge:*)",
      "Bash(git rebase:*)",
      "Bash(git reset:*)",
      "Bash(git stash:*)",
      "Bash(mkdir:*)",
      "Bash(cp:*)",
      "Bash(mv:*)",
      "Bash(chmod:*)",
      "Bash(chown:*)",
      "Bash(sed -i:*)",
      "Bash(docker exec:*)",
      "Bash(docker compose:*)",
      "Bash(curl:*)",
      "Bash(ops/release-backend.sh:*)",
      "Bash(bash ops/release-backend.sh:*)"
    ],
    "deny": [
      "WebFetch",
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./secrets/**)",
      "Read(./**/*.pem)",
      "Read(./**/*.key)",
      "Read(./**/*id_rsa*)",
      "Write(./.env)",
      "Write(./.env.*)",
      "Bash(sudo:*)",
      "Bash(rm -rf:*)",
      "Bash(shutdown:*)",
      "Bash(reboot:*)",
      "Bash(kill -9:*)",
      "Bash(git clean:*)",
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(git push origin main:*)",
      "Bash(git push -u origin main:*)",
      "Bash(git push --set-upstream origin main:*)",
      "Bash(git push origin HEAD:main:*)",
      "Bash(git push origin +main:*)",
      "Bash(docker compose down:*)",
      "Bash(docker compose rm:*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/ops/hooks/doctrine-gate.sh\""
          },
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/ops/hooks/deploy-gate.sh\""
          }
        ]
      }
    ]
  }
}
