{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sealai.local/schemas/permission-manifest.schema.json",
  "title": "GATE-02 object-exact permission manifest",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "gate_id", "created_at", "control_sha256", "objects"],
  "properties": {
    "schema_version": {"const": 1},
    "gate_id": {"enum": ["GATE-02A", "GATE-02B", "GATE-02C", "GATE-02D", "GATE-02E"]},
    "created_at": {"type": "string", "format": "date-time"},
    "control_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "objects": {"type": "array", "minItems": 1}
  },
  "allOf": [
    {
      "if": {"properties": {"gate_id": {"const": "GATE-02E"}}},
      "then": {"properties": {"objects": {"items": {"$ref": "#/$defs/gate02eObject"}}}},
      "else": {"properties": {"objects": {"items": {"$ref": "#/$defs/legacyObject"}}}}
    }
  ],
  "$defs": {
    "baseProperties": {
      "type": "object",
      "properties": {
        "path": {"type": "string", "pattern": "^/"},
        "type": {"enum": ["file", "directory"]},
        "device": {"type": "integer", "minimum": 0},
        "inode": {"type": "integer", "minimum": 0},
        "uid": {"type": "integer", "minimum": 0},
        "gid": {"type": "integer", "minimum": 0},
        "mode": {"type": "string", "pattern": "^0[0-7]{3}$"},
        "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "runtime_consumers": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
        "target_uid": {"type": "integer", "minimum": 0},
        "target_gid": {"type": "integer", "minimum": 0},
        "target_mode": {"type": "string", "pattern": "^0[0-7]{3}$"}
      }
    },
    "legacyObject": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "type", "device", "inode", "uid", "gid", "mode", "runtime_consumers", "target_uid", "target_gid", "target_mode"],
      "properties": {
        "path": {"type": "string", "pattern": "^/"},
        "type": {"enum": ["file", "directory"]},
        "device": {"type": "integer", "minimum": 0},
        "inode": {"type": "integer", "minimum": 0},
        "uid": {"type": "integer", "minimum": 0},
        "gid": {"type": "integer", "minimum": 0},
        "mode": {"type": "string", "pattern": "^0[0-7]{3}$"},
        "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "runtime_consumers": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
        "target_uid": {"type": "integer", "minimum": 0},
        "target_gid": {"type": "integer", "minimum": 0},
        "target_mode": {"type": "string", "pattern": "^0[0-7]{3}$"}
      },
      "allOf": [
        {"if": {"properties": {"type": {"const": "file"}}}, "then": {"required": ["sha256"]}, "else": {"not": {"required": ["sha256"]}}}
      ]
    },
    "gate02eObject": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path", "type", "device", "inode", "uid", "gid", "mode",
        "runtime_consumers", "target_uid", "target_gid", "target_mode",
        "material_kind", "lineage", "certbot_managed", "nginx_referenced",
        "renewal_config_path", "public_certificate_fingerprint"
      ],
      "properties": {
        "path": {"type": "string", "pattern": "^/"},
        "type": {"enum": ["file", "directory"]},
        "device": {"type": "integer", "minimum": 0},
        "inode": {"type": "integer", "minimum": 0},
        "uid": {"type": "integer", "minimum": 0},
        "gid": {"type": "integer", "minimum": 0},
        "mode": {"type": "string", "pattern": "^0[0-7]{3}$"},
        "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "runtime_consumers": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
        "target_uid": {"type": "integer", "minimum": 0},
        "target_gid": {"type": "integer", "minimum": 0},
        "target_mode": {"type": "string", "pattern": "^0[0-7]{3}$"},
        "material_kind": {"enum": ["public_certificate", "private_key", "renewal_config", "acme_account_metadata", "directory"]},
        "lineage": {"type": "string", "minLength": 1, "pattern": "^[^/\\\\]+$"},
        "certbot_managed": {"const": true},
        "nginx_referenced": {"type": "boolean"},
        "renewal_config_path": {"type": "string", "pattern": "^/"},
        "public_certificate_fingerprint": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
      },
      "allOf": [
        {
          "if": {"properties": {"material_kind": {"const": "private_key"}}},
          "then": {"not": {"required": ["sha256"]}},
          "else": {
            "if": {"properties": {"type": {"const": "file"}}},
            "then": {"required": ["sha256"]},
            "else": {"not": {"required": ["sha256"]}}
          }
        },
        {
          "if": {"properties": {"material_kind": {"const": "directory"}}},
          "then": {"properties": {"type": {"const": "directory"}}},
          "else": {"properties": {"type": {"const": "file"}}}
        }
      ]
    }
  }
}
