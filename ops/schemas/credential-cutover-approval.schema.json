{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sealai.local/schemas/credential-cutover-approval.schema.json",
  "title": "GATE-01 same-image credential cutover approval",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "gate_id", "decision", "scope", "approval_id", "approved_at", "expires_at", "production_git_sha", "release_freeze_state_id", "release_freeze_state_sha256", "compose_project", "compose_file_sha256", "control_sha256", "services"],
  "properties": {
    "schema_version": {"const": 1},
    "gate_id": {"const": "GATE-01"},
    "decision": {"const": "APPROVED"},
    "scope": {"const": "same-image-credential-cutover"},
    "approval_id": {"type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9_.-]{0,127}$"},
    "approved_at": {"type": "string", "format": "date-time"},
    "expires_at": {"type": "string", "format": "date-time"},
    "production_git_sha": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
    "release_freeze_state_id": {"type": "string", "minLength": 1},
    "release_freeze_state_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "compose_project": {"type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9_.-]{0,127}$"},
    "compose_file_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "control_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "services": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["service", "expected_fingerprint", "allowed_credential_keys"],
        "properties": {
          "service": {"type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9_.-]{0,127}$"},
          "expected_fingerprint": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
          "allowed_credential_keys": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "pattern": "^[A-Z][A-Z0-9_]{0,127}$"}}
        }
      }
    }
  }
}
