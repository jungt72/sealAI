#!/usr/bin/env sh
set -eu

docker exec -i backend python - <<'PY'
import asyncio
import json

from app.database import AsyncSessionLocal
from app.services.rag.paperless import (
    process_pending_paperless_documents,
    sync_paperless_to_rag,
)


async def main() -> None:
    async with AsyncSessionLocal() as session:
        sync = await sync_paperless_to_rag(session)
        processing = await process_pending_paperless_documents(session, limit=10)
        print(json.dumps({"sync": sync, "processing": processing}, ensure_ascii=False))


asyncio.run(main())
PY
