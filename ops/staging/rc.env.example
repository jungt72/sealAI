# sealingAI isolated release-candidate contract (NON-PRODUCTION).
#
# Copy this file to ops/staging/rc.env, replace every BLOCKED_EXTERNAL / digest
# placeholder, then chmod 600 ops/staging/rc.env. The validator does not source
# this file: it accepts only the exact keys below and literal, unquoted values.
# This example is deliberately not runnable.

SEALAI_RC_MODE=isolated-nonprod

# A separate, authorized seeding process must sanitize and restore both snapshots,
# rotate the database credential to the RC-only value, attest non-empty data, and
# create the hash-derived external volumes documented in RC_EVALUATION_ISOLATION.md.
RC_DATA_SEED_STATUS=BLOCKED_EXTERNAL
RC_POSTGRES_PASSWORD=YOUR_RC_ONLY_RANDOM_VALUE
RC_POSTGRES_SNAPSHOT_SHA256=REPLACE_WITH_64_LOWERCASE_HEX
RC_QDRANT_SNAPSHOT_SHA256=REPLACE_WITH_64_LOWERCASE_HEX
RC_AUTHORITY_EPOCH=sha256:REPLACE_WITH_64_LOWERCASE_HEX
RC_QDRANT_COLLECTION=sealai_rc_knowledge_REPLACE
RC_QDRANT_MEMORY_COLLECTION=sealai_rc_memory_REPLACE
RC_POSTGRES_IMAGE=docker.io/library/postgres:16.11-bookworm@sha256:REPLACE_WITH_64_LOWERCASE_HEX
RC_QDRANT_IMAGE=docker.io/qdrant/qdrant:v1.16.0@sha256:REPLACE_WITH_64_LOWERCASE_HEX

# The provider is an OpenAI-compatible, local-only deterministic stub. Its model
# IDs are deliberately RC-only so its output can never qualify as prod evidence.
RC_STUB_PROVIDER_STATUS=BLOCKED_EXTERNAL
RC_LLM_STUB_IMAGE=localhost/sealai-rc-llm-stub:v1@sha256:REPLACE_WITH_64_LOWERCASE_HEX

# Required only by ops/staging/up-staging-v2.sh (not by ops/run_eval.sh).
RC_WEB_STUB_STATUS=BLOCKED_EXTERNAL
RC_TLS_FIXTURE_STATUS=BLOCKED_EXTERNAL
RC_NGINX_IMAGE=docker.io/library/nginx:1.29.4@sha256:REPLACE_WITH_64_LOWERCASE_HEX
RC_AUTH_STUB_IMAGE=localhost/sealai-rc-auth-stub:v1@sha256:REPLACE_WITH_64_LOWERCASE_HEX
RC_FRONTEND_STUB_IMAGE=localhost/sealai-rc-frontend-stub:v1@sha256:REPLACE_WITH_64_LOWERCASE_HEX
