{
  "kind": "singleType",
  "collectionName": "globals",
  "info": {
    "singularName": "global",
    "pluralName": "globals",
    "displayName": "Global",
    "description": "Global site settings including logo, navigation, and footer"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "siteName": {
      "type": "string",
      "required": true,
      "default": "SealAI"
    },
    "logo": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": ["images"]
    },
    "navbarLinks": {
      "type": "component",
      "repeatable": true,
      "component": "shared.link"
    },
    "footerColumns": {
      "type": "component",
      "repeatable": true,
      "component": "shared.footer-column"
    },
    "footerBottomLinks": {
      "type": "component",
      "repeatable": true,
      "component": "shared.link"
    },
    "copyrightText": {
      "type": "string",
      "default": "© 2025 SealAI GmbH. Alle Rechte vorbehalten."
    },
    "sectionNavItems": {
      "type": "component",
      "repeatable": true,
      "component": "shared.link"
    }
  }
}
