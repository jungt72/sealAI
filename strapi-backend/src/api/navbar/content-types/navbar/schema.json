{
  "kind": "singleType",
  "collectionName": "navbars",
  "info": {
    "singularName": "navbar",
    "pluralName": "navbars",
    "displayName": "Navbar",
    "description": "Main navigation configuration"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "logo": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": [
        "images"
      ]
    },
    "brand_name": {
      "type": "string",
      "default": "SEALAI"
    },
    "items": {
      "type": "component",
      "repeatable": true,
      "component": "shared.link"
    },
    "show_search": {
      "type": "boolean",
      "default": true
    },
    "show_menu": {
      "type": "boolean",
      "default": true
    }
  }
}
