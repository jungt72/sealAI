# ===== Runtime =====
# Copy this file to strapi-backend/.env and fill in secure values
NODE_ENV=production
HOST=0.0.0.0
PORT=1337
URL=https://sealai.net
PUBLIC_URL=https://sealai.net
ADMIN_URL=/admin
SERVE_ADMIN=true

# ===== Database (Postgres recommended) =====
DATABASE_CLIENT=postgres
DATABASE_HOST=postgres
DATABASE_PORT=5432
DATABASE_NAME=strapi_db
DATABASE_USERNAME=strapi_user
DATABASE_PASSWORD=CHANGEME_STRAPI_DB_PASSWORD
DATABASE_SCHEMA=public
DATABASE_SSL=false

# ===== Security (ROTATE FOR PRODUCTION) =====
APP_KEYS=CHANGEME_APP_KEY_1,CHANGEME_APP_KEY_2,CHANGEME_APP_KEY_3,CHANGEME_APP_KEY_4
API_TOKEN_SALT=CHANGEME_API_TOKEN_SALT
TRANSFER_TOKEN_SALT=CHANGEME_TRANSFER_TOKEN_SALT
ADMIN_JWT_SECRET=CHANGEME_ADMIN_JWT_SECRET
ADMIN_AUTH_SECRET=CHANGEME_ADMIN_AUTH_SECRET
JWT_SECRET=CHANGEME_USER_JWT_SECRET
ENCRYPTION_KEY=CHANGEME_TRANSFER_ENCRYPTION_KEY

# ===== Optional =====
STRAPI_TELEMETRY_DISABLED=true
