#!/bin/sh
set -eu

repo_root="$(git rev-parse --show-toplevel)"
scanner="$repo_root/ops/check-secret-hygiene.py"
resolver="$repo_root/ops/resolve-secret-scan-range.py"
zero=0000000000000000000000000000000000000000
saw_ref=false

while read -r local_ref local_oid remote_ref remote_oid; do
  saw_ref=true

  # A deleted remote ref has no new tree or commit to scan.
  if [ "$local_oid" = "$zero" ]; then
    continue
  fi

  python3 "$scanner" --tree "$local_oid"

  default_ref="$(git symbolic-ref -q refs/remotes/origin/HEAD 2>/dev/null || true)"
  if [ -z "$default_ref" ]; then
    default_ref=refs/heads/main
  fi
  default_branch="${default_ref##*/}"
  ref_name="${remote_ref#refs/heads/}"
  revision_range="$(python3 "$resolver" \
    --event push \
    --before "$remote_oid" \
    --after "$local_oid" \
    --default-ref "$default_ref" \
    --ref-name "$ref_name" \
    --default-branch "$default_branch")"

  python3 "$scanner" --range "$revision_range"
done

if [ "$saw_ref" = false ]; then
  python3 "$scanner" --tree HEAD
fi
