# Official pgvector image: PostgreSQL 16 plus pgvector 0.8.5. The manifest is
# immutable; no mutable apt repository or unauthenticated build download is used.
FROM pgvector/pgvector:0.8.5-pg16-bookworm@sha256:1d533553fefe4f12e5d80c7b80622ba0c382abb5758856f52983d8789179f0fb

RUN printf '%s\n' "shared_preload_libraries = 'vector'" \
  >> /usr/share/postgresql/postgresql.conf.sample
