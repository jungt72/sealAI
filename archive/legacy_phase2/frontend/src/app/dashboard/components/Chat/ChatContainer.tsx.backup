// frontend/src/app/dashboard/components/Chat/ChatContainer.tsx
"use client";

import React, {
  useCallback,
  useEffect,
  useRef,
  useState,
} from "react";
import { useSession } from "next-auth/react";
import { useChatThreadId } from "@/lib/useChatThreadId";
import { useAccessToken } from "@/lib/useAccessToken";
import { useChat } from "@/lib/useChat";
import ChatHistory from "./ChatHistory";
import AdvancedInputBar from "../AdvancedInputBar";

export default function ChatContainer() {
  const { data: session, status } = useSession();
  const isAuthed = status === "authenticated";

  const chatId = useChatThreadId();
  const token = useAccessToken();

  const {
    connected,
    isStreaming,
    messages,
    lastError,
    askMissing,
    streamingMessageId,
    sendMessage,
    cancel,
    parameters,\n    showParameterForm,\n    updateParameter,\n    closeParameterForm,
  } = useChat({ chatId, token: token ?? null });

  const [inputValue, setInputValue] = useState("");
  const [hasStarted, setHasStarted] = useState(false);

  /** Scrollbarer Bereich des Chatverlaufs */
  const scrollRef = useRef<HTMLDivElement | null>(null);

  /** Letzte sichtbare User-/Assistant-Nachricht (für „oben einrasten“) */
  const lastMessageRef = useRef<HTMLDivElement | null>(null);

  /** „Zum Ende“-Button ein-/ausblenden */
  const [showScrollButton, setShowScrollButton] = useState(false);

  /** Flag: wurde gerade eine Nachricht gesendet? */
  const [justSent, setJustSent] = useState(false);

  useEffect(() => {
    setHasStarted(false);
  }, [chatId]);

  // --- Scroll-Helfer --------------------------------------------------------

  const scrollToBottom = useCallback(
    (behavior: ScrollBehavior = "auto") => {
      const container = scrollRef.current;
      if (!container) return;

      container.scrollTo({
        top: container.scrollHeight - container.clientHeight,
        behavior,
      });
    },
    [],
  );

  /** Wie bei Grok/ChatGPT: letzte User-Message nahe an den oberen Rand scrollen */
  const scrollLastMessageToTop = useCallback(() => {
    const container = scrollRef.current;
    const target = lastMessageRef.current;
    if (!container || !target) return;

    const containerTop = container.offsetTop;
    const targetTop = target.offsetTop;

    const marginTop = 16; // bisschen Luft wie bei Grok
    const desiredTop = Math.max(targetTop - containerTop - marginTop, 0);

    container.scrollTo({
      top: desiredTop,
      behavior: "smooth",
    });
  }, []);

  /** Button-Anzeige abhängig von Abstand zum unteren Rand */
  const handleScroll = useCallback(() => {
    const container = scrollRef.current;
    if (!container) return;

    const distanceToBottom =
      container.scrollHeight - container.scrollTop - container.clientHeight;
    setShowScrollButton(distanceToBottom > 200);
  }, []);

  /** Auto-Scroll beim Streamen – aber nur, wenn man in der Nähe des Endes ist */
  useEffect(() => {
    const container = scrollRef.current;
    if (!container) return;

    const distanceToBottom =
      container.scrollHeight - container.scrollTop - container.clientHeight;

    // Nur auto-scrollen, wenn man nicht weit nach oben gescrollt ist
    if (distanceToBottom < 120) {
      scrollToBottom("smooth");
    }
  }, [messages, isStreaming, scrollToBottom]);

  /** Nach dem Senden: komplette Ansicht so verschieben, dass die neue Frage oben sitzt */
  useEffect(() => {
    if (!justSent) return;

    // kleine Verzögerung, damit DOM & Layout fertig sind
    const id = window.setTimeout(() => {
      scrollLastMessageToTop();
      setJustSent(false);
    }, 80);

    return () => window.clearTimeout(id);
  }, [justSent, scrollLastMessageToTop, messages.length]);

  // --- Senden / UI-Status ---------------------------------------------------

  const firstName = (session?.user?.name || "").split(" ")[0] || "";
  const hasThread = Boolean(chatId);
  const sendingDisabled = !isAuthed || !connected || !hasThread;
  const isInitial =
    messages.length === 0 && !hasStarted && !askMissing;

  const askMessage: string | null =
    askMissing && typeof askMissing.message === "string"
      ? askMissing.message
      : null;

  const basePlaceholder = isAuthed
    ? !hasThread
      ? "Initialisiere Sitzung…"
      : connected
      ? "Was möchtest du wissen?"
      : "Verbinde…"
    : "Bitte anmelden, um zu schreiben";

  const placeholder = askMessage || basePlaceholder;

  const handleSend = useCallback(
    (msg: string) => {
      if (sendingDisabled) return;
      const content = msg.trim();
      if (!content) return;

      setHasStarted(true);
      setJustSent(true);
      sendMessage(content);
      setInputValue("");
    },
    [sendingDisabled, sendMessage],
  );

  // --------------------------------------------------------------------------

  return (
    <div
      className="flex flex-col w-full bg-transparent relative"
      style={{ height: "100dvh" }}
    >
      {isInitial ? (
        // Startscreen zentriert
        <div className="flex min-h-[80vh] w-full items-center justify-center">
          <div className="w-full max-w-[800px] px-4">
            <div className="text-2xl md:text-3xl font-bold text-gray-800 text-center leading-tight select-none">
              Willkommen zurück{firstName ? `, ${firstName}` : ""}!
            </div>
            <div className="text-base md:text-lg text-gray-500 mb-3 text-center leading-snug font-medium select-none">
              Schön, dass du hier bist.
            </div>
            <div className="text-xs text-center mb-4">
              {isAuthed ? (
                !hasThread ? (
                  <span className="text-amber-600">
                    Initialisiere Sitzung…
                  </span>
                ) : connected ? (
                  <span className="text-emerald-600">SSE verbunden</span>
                ) : (
                  <span className="text-amber-600">Verbinde SSE…</span>
                )
              ) : (
                <span className="text-gray-500">
                  Bitte anmelden
                </span>
              )}
            </div>

            <AdvancedInputBar
              value={inputValue}
              setValue={setInputValue}
              onSend={handleSend}
              onStop={() => cancel()}
              disabled={sendingDisabled}
              streaming={isStreaming}
              placeholder={placeholder}
            />

            {!isAuthed && (
              <div className="mt-2 text-xs text-gray-500 text-center">
                Du musst angemeldet sein, um Nachrichten zu senden.
              </div>
            )}
            {lastError && (
              <div className="mt-2 text-xs text-red-500 text-center select-none">
                Fehler: {lastError}
              </div>
            )}
          </div>
        </div>
      ) : (
        <>
          {/* Scrollbarer Chat-Verlauf */}
          <div
            ref={scrollRef}
            onScroll={handleScroll}
            className="flex-1 w-full pb-36"
            style={{
              overflowY: "auto",
              WebkitOverflowScrolling: "touch",
              display: "flex",
              flexDirection: "column",
              paddingBottom: "env(safe-area-inset-bottom, 16px)",
            }}
          >
            <div
              className="flex-1 flex flex-col pt-4"
              style={{ minHeight: "100%" }}
            >
              <ChatHistory
                messages={messages}
                askMissing={askMissing}
                streaming={isStreaming}
                streamingMessageId={streamingMessageId}
                lastMessageRef={lastMessageRef}
              />
            </div>
          </div>

          {/* „Zum Ende“-Button */}
          <button
            className={`fixed bottom-28 right-6 z-30 rounded-full bg-sky-600 text-white px-4 py-2 shadow-lg hover:bg-sky-700 transition-all duration-300 ${
              showScrollButton
                ? "opacity-70 translate-y-0"
                : "opacity-0 translate-y-4 pointer-events-none"
            }`}
            onClick={() => scrollToBottom("smooth")}
            type="button"
          >
            Zum Ende
          </button>

          {/* Eingabefeld sticky unten */}
          <div className="sticky bottom-0 left-0 right-0 z-20 flex justify-center bg-transparent pb-0 w-full">
            <div className="w-full max-w-[800px] pointer-events-auto px-4 pb-3">
              <AdvancedInputBar
                value={inputValue}
                setValue={setInputValue}
                onSend={handleSend}
                onStop={() => cancel()}
                disabled={sendingDisabled}
                streaming={isStreaming}
                placeholder={placeholder}
              />
              {!isAuthed && (
                <div className="mt-2 text-xs text-gray-500">
                  Du musst angemeldet sein, um Nachrichten zu senden.
                </div>
              )}
              {lastError && (
                <div className="mt-2 text-xs text-red-500 select-none">
                  Fehler: {lastError}
                </div>
              )}
            </div>
          </div>
        </>
      )}
    </div>
  );
}
