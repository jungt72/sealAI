version: "3.9"
services:
  postgres:
    image: postgres:15
    container_name: postgres
    restart: unless-stopped
    env_file: [ ./.env.dev ]
    environment:
      POSTGRES_DB: sealai
      POSTGRES_USER: sealai
      STRAPI_DB_NAME: ${STRAPI_DB_NAME:-strapi_db}
      STRAPI_DB_USER: ${STRAPI_DB_USER:-strapi_user}
      STRAPI_DB_PASSWORD: ${STRAPI_DB_PASSWORD:?Set STRAPI_DB_PASSWORD in your environment}
    volumes:
      - pgdata:/var/lib/postgresql/data
      - ./postgres/init-strapi.sh:/docker-entrypoint-initdb.d/init-strapi.sh:ro
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U $$POSTGRES_USER -d $$POSTGRES_DB"]
      interval: 10s
      timeout: 5s
      retries: 5

  redis:
    image: redis/redis-stack-server:7.4.0-v6
    container_name: redis
    restart: unless-stopped
    ports: ["127.0.0.1:6379:6379"]
    environment:
      REDIS_ARGS: "--appendonly yes --save 900 1 --save 300 10 --save 60 10000"
      REDIS_PASSWORD: "${REDIS_PASSWORD:-sealai_dev_redis_2025}"
    volumes:
      - redis-data:/data
    healthcheck:
      test: ["CMD", "redis-cli", "PING"]
      interval: 10s
      timeout: 5s
      retries: 5

  qdrant:
    image: qdrant/qdrant:v1.15.0
    container_name: qdrant
    command: ["./entrypoint.sh"]
    restart: unless-stopped
    ports: ["6333:6333", "6334:6334"]
    volumes:
      - qdrant_storage:/qdrant/storage

  keycloak:
    build:
      context: ./keycloak
      dockerfile: Dockerfile
    image: ghcr.io/jungt72/sealai-keycloak:latest
    container_name: keycloak
    depends_on:
      - postgres
    restart: unless-stopped
    env_file: [ .env.dev ]
    environment:
      KC_DB: postgres
      KC_DB_URL: jdbc:postgresql://postgres:5432/sealai
      KC_DB_USERNAME: sealai
      KC_PROXY: edge
      KC_PROXY_HEADERS: xforwarded
      KC_HEALTH_ENABLED: "true"
      KC_METRICS_ENABLED: "true"
      KC_CACHE_STACK: tcp
      KC_CACHE_NODE_NAME: "keycloak-node"
      KC_HOSTNAME_STRICT: "true"
    ports: ["8080:8080"]

  backend:
    build:
      context: ./backend
      dockerfile: Dockerfile
    image: sealai-backend:local
    container_name: backend
    depends_on:
      postgres:
        condition: service_healthy
      redis:
        condition: service_started
      qdrant:
        condition: service_started
      keycloak:
        condition: service_started
    restart: unless-stopped
    env_file: [ ./backend/.env, ./.env.dev ]
    environment:
      ROUTER_MODEL: gpt-5-nano
      ROUTER_TEMP: "0.0"
      ROUTER_MAX_TOKENS: "256"
      ROUTER_JSON_MODE: "1"
      SEALAI_LOG_LEVEL: DEBUG
      GENERATION_MODEL: gpt-5-large
      GENERATION_TEMP: "0.2"
      GENERATION_MAX_TOKENS: "1024"
      WS_AUTH_OPTIONAL: "1"
      CONSULT_GRAPH_DEBUG: "1"
      CONSULT_GRAPH_DEBUG_LEVEL: "debug"

      USE_REDIS_CHECKPOINTER: "1"
      CHECKPOINTER_NAMESPACE_MAIN: "sealai:main"

    command: ["uvicorn", "app.main:app", "--host", "0.0.0.0", "--port", "8000", "--log-level", "debug"]
    ports: ["8000:8000"]
    healthcheck:
      test: ["CMD", "curl", "-fsS", "http://localhost:8000/api/v1/ping"]
      interval: 60s
      timeout: 5s
      retries: 5
      start_period: 30s

  frontend:
    image: ghcr.io/jungt72/sealai-frontend:latest
    container_name: frontend
    env_file: [ ./.env.dev ]
    build:
      context: ./frontend
      args:
        NEXT_PUBLIC_API_BASE: "${NEXT_PUBLIC_API_BASE:-http://localhost:8000}"
        NEXT_PUBLIC_SITE_URL: "${NEXT_PUBLIC_SITE_URL:-http://localhost:3000}"
        NEXTAUTH_URL: "${NEXTAUTH_URL:-http://localhost:3000}"
        KEYCLOAK_ISSUER: "${KEYCLOAK_ISSUER:-http://keycloak:8080/realms/sealAI}"
        KEYCLOAK_CLIENT_ID: "${KEYCLOAK_CLIENT_ID:-nextauth}"
        NEXT_PUBLIC_STRAPI_URL: "${NEXT_PUBLIC_STRAPI_URL:-http://strapi:1337}"
    depends_on:
      - backend
      - strapi
    restart: unless-stopped
    ports: ["3000:3000"]

  nginx:
    image: nginx:latest
    container_name: nginx
    depends_on:
      frontend:
        condition: service_started
      backend:
        condition: service_started
      keycloak:
        condition: service_started
      strapi:
        condition: service_started
      odoo:
        condition: service_started
    restart: unless-stopped
    ports: ["80:80", "443:443"]
    volumes:
      - ./nginx/default.conf:/etc/nginx/conf.d/default.conf:ro
      - ./nginx/00-tuning.conf:/etc/nginx/conf.d/00-tuning.conf:ro
      - ./nginx/www:/var/www/certbot:ro
      - /etc/letsencrypt:/etc/letsencrypt:ro
      - ./nginx/logs:/var/log/nginx
    healthcheck:
      test: ["CMD-SHELL", "test -s /var/run/nginx.pid || exit 1"]
      interval: 15s
      timeout: 5s
      retries: 5

  strapi:
    build:
      context: ./strapi-backend
      dockerfile: Dockerfile
    container_name: strapi
    restart: unless-stopped
    deploy:
      resources:
        limits:
          memory: 1G
        reservations:
          memory: 512M
    logging:
      driver: "json-file"
      options:
        max-size: "10m"
        max-file: "3"
    env_file:
      - ./strapi-backend/.env
    environment:
      # Dev-Modus, damit du Content Types (z.B. Homepage) anlegen kannst
      NODE_ENV: development
    command: ["npm", "run", "develop"]
    volumes:
      - strapi_uploads:/app/public/uploads
    depends_on:
      postgres:
        condition: service_healthy

  odoo-db:
    image: postgres:15
    container_name: odoo-db
    restart: unless-stopped
    environment:
      - POSTGRES_DB=postgres
      - POSTGRES_PASSWORD=odoo
      - POSTGRES_USER=odoo
    volumes:
      - odoo-db-data:/var/lib/postgresql/data
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U odoo"]
      interval: 10s
      timeout: 5s
      retries: 5

  odoo:
    image: odoo:16
    container_name: odoo
    restart: unless-stopped
    depends_on:
      odoo-db:
        condition: service_healthy
    ports:
      - "8069:8069"
    volumes:
      - odoo-web-data:/var/lib/odoo
      - ./odoo/addons:/mnt/extra-addons
    environment:
      - HOST=odoo-db
      - USER=odoo
      - PASSWORD=odoo

volumes:
  pgdata:
  qdrant_storage:
  redis-data:
  strapi_uploads:
  odoo-db-data:
  odoo-web-data:
