# Copy to paperless/.env only after the selected images have been verified.
# The Compose contract rejects mutable tags; placeholders are intentionally not
# runnable and contain no credentials.
PAPERLESS_IMAGE=ghcr.io/paperless-ngx/paperless-ngx:TAG@sha256:REPLACE_WITH_64_HEX_DIGEST
PAPERLESS_GOTENBERG_IMAGE=docker.io/gotenberg/gotenberg:TAG@sha256:REPLACE_WITH_64_HEX_DIGEST
PAPERLESS_TIKA_IMAGE=docker.io/apache/tika:TAG@sha256:REPLACE_WITH_64_HEX_DIGEST
