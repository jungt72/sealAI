{
  "id": null,
  "uid": "sealai-business",
  "title": "SeaLAI Business",
  "tags": [
    "sealai",
    "business",
    "prometheus"
  ],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 2,
  "refresh": "10s",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "panels": [
    {
      "type": "timeseries",
      "title": "Chat Requests/s",
      "id": 1,
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 0
      },
      "targets": [
        {
          "expr": "sum by (path) (rate(sealai_http_requests_total{path=~\"/api/agent/chat|/api/agent/chat/stream\"}[5m]))",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Workspace Requests/s",
      "id": 2,
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 0
      },
      "targets": [
        {
          "expr": "sum by (path) (rate(sealai_http_requests_total{path=~\".*/workspace/.*|.*/state/workspace.*\"}[5m]))",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Review Requests/s",
      "id": 3,
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 8
      },
      "targets": [
        {
          "expr": "sum by (path) (rate(sealai_http_requests_total{path=~\"/api/agent/review|/api/agent/review/seed\"}[5m]))",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "RFQ Surface Requests/s",
      "id": 4,
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 8
      },
      "targets": [
        {
          "expr": "sum by (path) (rate(sealai_http_requests_total{path=~\".*/rfq-document.*|.*/rfq-generate-pdf.*|.*/rfq-handover.*|.*/rfq-confirm.*|/api/v1/rfq/download\"}[5m]))",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Business Surface 5xx/s",
      "id": 5,
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 16
      },
      "targets": [
        {
          "expr": "sum(rate(sealai_http_requests_total{status=~\"5..\",path=~\"/api/agent/chat|/api/agent/chat/stream|.*/workspace/.*|.*/state/workspace.*|/api/agent/review|/api/agent/review/seed|.*/rfq-document.*|.*/rfq-generate-pdf.*|.*/rfq-handover.*|.*/rfq-confirm.*|/api/v1/rfq/download\"}[5m]))",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Business Surface Latency p95 (s)",
      "id": 6,
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 16
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(sealai_http_request_duration_seconds_bucket{path=~\"/api/agent/chat|/api/agent/chat/stream|.*/workspace/.*|.*/state/workspace.*|/api/agent/review|/api/agent/review/seed|.*/rfq-document.*|.*/rfq-generate-pdf.*|.*/rfq-handover.*|.*/rfq-confirm.*|/api/v1/rfq/download\"}[5m])))",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Gate Route Decisions/s",
      "id": 7,
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 24
      },
      "targets": [
        {
          "expr": "sum by (route) (rate(sealai_gate_route_decisions_total[5m]))",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Inquiries Created & Sent/s",
      "id": 8,
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 24
      },
      "targets": [
        {
          "expr": "sum by (status) (rate(sealai_inquiry_created_total[5m]))",
          "legendFormat": "created {{status}}",
          "refId": "A"
        },
        {
          "expr": "sum by (status) (rate(sealai_inquiry_sent_total[5m]))",
          "legendFormat": "sent {{status}}",
          "refId": "B"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "fit_score Distribution p50/p95",
      "id": 9,
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 32
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(sealai_fit_score_bucket[5m])) by (le))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(sealai_fit_score_bucket[5m])) by (le))",
          "legendFormat": "p95",
          "refId": "B"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "LLM Token Consumption/s",
      "id": 10,
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 32
      },
      "targets": [
        {
          "expr": "sum by (model, type) (rate(sealai_llm_tokens_total[5m]))",
          "refId": "A"
        }
      ]
    }
  ]
}