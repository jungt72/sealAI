{
  "id": null,
  "uid": "sealai-v2-control-plane",
  "title": "sealingAI V2 Control Plane",
  "tags": ["sealai", "v2", "cost", "auth", "recovery"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 4,
  "refresh": "30s",
  "time": {"from": "now-24h", "to": "now"},
  "panels": [
    {
      "type": "stat",
      "title": "Daily Provider Budget Used",
      "id": 1,
      "gridPos": {"h": 6, "w": 8, "x": 0, "y": 0},
      "targets": [{"expr": "sum(sealai_v2_provider_spend_minor_units{period=\"daily\"}) / clamp_min(sum(sealai_v2_provider_budget_limit_minor_units{period=\"daily\"}), 1)", "refId": "A"}]
    },
    {
      "type": "stat",
      "title": "Backup Age (h)",
      "id": 2,
      "gridPos": {"h": 6, "w": 8, "x": 8, "y": 0},
      "targets": [{"expr": "max((time() - sealai_backup_last_success_timestamp_seconds) / 3600)", "refId": "A"}]
    },
    {
      "type": "stat",
      "title": "Offsite Age (h)",
      "id": 3,
      "gridPos": {"h": 6, "w": 8, "x": 16, "y": 0},
      "targets": [{"expr": "max((time() - sealai_offsite_backup_last_success_timestamp_seconds) / 3600)", "refId": "A"}]
    },
    {
      "type": "timeseries",
      "title": "Quota Denials/s",
      "id": 4,
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 6},
      "targets": [{"expr": "sum(rate(sealai_v2_quota_denials_total[5m]))", "refId": "A"}]
    },
    {
      "type": "timeseries",
      "title": "Authentication Denials/s",
      "id": 5,
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 6},
      "targets": [{"expr": "sum(rate(sealai_v2_auth_denials_total[5m]))", "refId": "A"}]
    },
    {
      "type": "timeseries",
      "title": "Provider Spend and Limit (minor units)",
      "id": 6,
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 14},
      "targets": [
        {"expr": "sum by (provider) (sealai_v2_provider_spend_minor_units{period=\"daily\"})", "legendFormat": "spend {{provider}}", "refId": "A"},
        {"expr": "sum by (provider) (sealai_v2_provider_budget_limit_minor_units{period=\"daily\"})", "legendFormat": "limit {{provider}}", "refId": "B"}
      ]
    },
    {
      "type": "timeseries",
      "title": "Recovery Evidence Valid",
      "id": 7,
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 14},
      "targets": [{"expr": "sealai_backup_receipt_valid", "legendFormat": "{{component}}", "refId": "A"}]
    }
  ]
}
