{
  "id": null,
  "uid": "sealai-v2-data-projection",
  "title": "sealingAI V2 Data and Projection",
  "tags": ["sealai", "v2", "qdrant", "outbox"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 4,
  "refresh": "10s",
  "time": {"from": "now-6h", "to": "now"},
  "panels": [
    {
      "type": "stat",
      "title": "Qdrant Up",
      "id": 1,
      "gridPos": {"h": 6, "w": 6, "x": 0, "y": 0},
      "targets": [{"expr": "max(up{job=\"sealai-qdrant\"})", "refId": "A"}]
    },
    {
      "type": "stat",
      "title": "Projection Drift Rows",
      "id": 2,
      "gridPos": {"h": 6, "w": 6, "x": 6, "y": 0},
      "targets": [{"expr": "sum(sealai_v2_qdrant_sync_drift)", "refId": "A"}]
    },
    {
      "type": "stat",
      "title": "Oldest Pending (s)",
      "id": 3,
      "gridPos": {"h": 6, "w": 6, "x": 12, "y": 0},
      "targets": [{"expr": "max(sealai_v2_outbox_oldest_pending_seconds)", "refId": "A"}]
    },
    {
      "type": "stat",
      "title": "Metrics Collection Healthy",
      "id": 4,
      "gridPos": {"h": 6, "w": 6, "x": 18, "y": 0},
      "targets": [{"expr": "min(sealai_v2_outbox_metrics_collection_success)", "refId": "A"}]
    },
    {
      "type": "timeseries",
      "title": "Outbox Rows by Queue and Status",
      "id": 5,
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 6},
      "targets": [{"expr": "sum by (queue, status) (sealai_v2_outbox_rows)", "legendFormat": "{{queue}} / {{status}}", "refId": "A"}]
    },
    {
      "type": "timeseries",
      "title": "LLM Calls/s",
      "id": 6,
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 6},
      "targets": [{"expr": "sum by (provider, model, status) (rate(sealai_v2_llm_calls_total[5m]))", "legendFormat": "{{provider}} / {{model}} / {{status}}", "refId": "A"}]
    },
    {
      "type": "timeseries",
      "title": "Provider Failures/s by Category",
      "id": 7,
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 14},
      "targets": [{"expr": "sum by (provider, category) (rate(sealai_v2_llm_failures_total[5m]))", "legendFormat": "{{provider}} / {{category}}", "refId": "A"}]
    },
    {
      "type": "timeseries",
      "title": "Route Decisions/s",
      "id": 8,
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 14},
      "targets": [{"expr": "sum by (route) (rate(sealai_v2_route_decisions_total[5m]))", "legendFormat": "{{route}}", "refId": "A"}]
    }
  ]
}
