{
  "id": null,
  "uid": "sealai-v2-operations",
  "title": "sealingAI V2 Operations",
  "tags": ["sealai", "v2", "operations"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 4,
  "refresh": "10s",
  "time": {"from": "now-6h", "to": "now"},
  "panels": [
    {
      "type": "stat",
      "title": "Backend V2 Up",
      "id": 1,
      "gridPos": {"h": 6, "w": 6, "x": 0, "y": 0},
      "targets": [{"expr": "max(up{job=\"sealai-backend-v2\"})", "refId": "A"}]
    },
    {
      "type": "stat",
      "title": "Outbox Worker Up",
      "id": 2,
      "gridPos": {"h": 6, "w": 6, "x": 6, "y": 0},
      "targets": [{"expr": "max(up{job=\"sealai-backend-v2-worker\"})", "refId": "A"}]
    },
    {
      "type": "stat",
      "title": "Firing Critical Alerts",
      "id": 3,
      "gridPos": {"h": 6, "w": 6, "x": 12, "y": 0},
      "targets": [{"expr": "count(ALERTS{alertstate=\"firing\",severity=~\"critical|emergency\"})", "refId": "A"}]
    },
    {
      "type": "stat",
      "title": "Redis Memory Ratio",
      "id": 4,
      "gridPos": {"h": 6, "w": 6, "x": 18, "y": 0},
      "targets": [{"expr": "sealai:redis_memory_usage_ratio", "refId": "A"}]
    },
    {
      "type": "timeseries",
      "title": "HTTP Requests/s by Status",
      "id": 5,
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 6},
      "targets": [{"expr": "sum by (status) (rate(http_requests_total{job=\"sealai-backend-v2\"}[5m]))", "legendFormat": "{{status}}", "refId": "A"}]
    },
    {
      "type": "timeseries",
      "title": "HTTP Latency p95 (s)",
      "id": 6,
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 6},
      "targets": [{"expr": "sealai:http_p95_seconds_5m", "refId": "A"}]
    },
    {
      "type": "timeseries",
      "title": "Filesystem Usage (%)",
      "id": 7,
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 14},
      "targets": [{"expr": "sealai:node_filesystem_usage_percent", "legendFormat": "{{mountpoint}}", "refId": "A"}]
    },
    {
      "type": "timeseries",
      "title": "HTTP Error Ratios",
      "id": 8,
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 14},
      "targets": [
        {"expr": "sealai:http_4xx_ratio_5m", "legendFormat": "4xx", "refId": "A"},
        {"expr": "sealai:http_5xx_ratio_5m", "legendFormat": "5xx", "refId": "B"}
      ]
    }
  ]
}
