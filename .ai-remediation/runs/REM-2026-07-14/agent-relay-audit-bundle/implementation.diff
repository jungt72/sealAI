+def _load_json_file(path: Path, *, limit: int, label: str) -> tuple[Any, bytes]:
+    raw = _read_regular(path, limit=limit, label=label)
+    _assert_no_secret(raw, label=label)
+    return _parse_json(raw, label=label), raw
