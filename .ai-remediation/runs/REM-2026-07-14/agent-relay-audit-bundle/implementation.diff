+
+def test_missing_dependency_duplicate_id_and_age_only_evidence_fail_closed():
+    module = _module()
+    missing = _fixture()
+    missing["objects"][0]["dependencies"] = ["service:not-present"]
+    with pytest.raises(module.InventoryError, match="missing dependency"):
