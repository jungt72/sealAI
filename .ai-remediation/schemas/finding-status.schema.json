{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sealingai.local/schemas/finding-status.schema.json",
  "title": "sealingAI remediation finding",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "finding_id",
    "title",
    "original_severity",
    "verified_severity",
    "verification_status",
    "production_affected",
    "affected_components",
    "root_cause",
    "dependencies",
    "remediation_type",
    "implementation_status",
    "evidence_before",
    "changes",
    "tests",
    "production_action_required",
    "approval_gate",
    "rollback",
    "evidence_after",
    "residual_risk"
  ],
  "properties": {
    "finding_id": {"type": "string", "pattern": "^[A-Z]+-[0-9]{3}$"},
    "title": {"type": "string", "minLength": 1},
    "original_severity": {"enum": ["CRITICAL", "HIGH", "MEDIUM", "LOW"]},
    "verified_severity": {"enum": ["CRITICAL", "HIGH", "MEDIUM", "LOW"]},
    "verification_status": {"enum": ["REPORTED", "CONFIRMED", "PARTIALLY_CONFIRMED", "NO_LONGER_PRESENT", "FALSE_POSITIVE"]},
    "production_affected": {"type": "boolean"},
    "affected_components": {"type": "array", "items": {"type": "string"}, "minItems": 1},
    "root_cause": {"type": "string", "minLength": 1},
    "dependencies": {"type": "array", "items": {"type": "string"}},
    "remediation_type": {
      "type": "array",
      "items": {"enum": ["code", "configuration", "infrastructure", "operational", "credential_rotation", "data_migration", "governance"]},
      "minItems": 1,
      "uniqueItems": true
    },
    "implementation_status": {"enum": ["REPORTED", "CONFIRMED", "IN_PROGRESS", "IMPLEMENTED_NOT_DEPLOYED", "DEPLOYED_UNVERIFIED", "VERIFIED", "BLOCKED_EXTERNAL", "NO_LONGER_PRESENT", "FALSE_POSITIVE"]},
    "evidence_before": {"type": "array", "items": {"type": "string"}},
    "changes": {"type": "array", "items": {"type": "string"}},
    "tests": {"type": "array", "items": {"type": "string"}},
    "production_action_required": {"type": "boolean"},
    "approval_gate": {"type": ["string", "null"], "pattern": "^GATE-[0-9]{2}$"},
    "rollback": {"type": "string", "minLength": 1},
    "evidence_after": {"type": "array", "items": {"type": "string"}},
    "residual_risk": {"type": "string"}
  }
}
