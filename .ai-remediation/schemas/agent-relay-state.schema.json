{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sealingai.local/schemas/agent-relay-state.schema.json",
  "title": "Fail-closed agent relay state",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "contract_id",
    "run_id",
    "baseline_commit",
    "build_contract_sha256",
    "bundle_hashes",
    "prepared_at",
    "production_query_performed",
    "production_mutation_performed",
    "api_fallback_used",
    "claude_invocations",
    "contract_audit",
    "implementation",
    "remediation_captures",
    "tests",
    "diff_audits",
    "draft_pr",
    "ready_for_draft_pr",
    "draft_pr_body_sha256"
  ],
  "properties": {
    "schema_version": {"const": 1},
    "contract_id": {"type": "string", "pattern": "^[a-z0-9][a-z0-9._-]{2,63}$"},
    "run_id": {"type": "string", "pattern": "^[A-Z0-9][A-Z0-9._-]{2,63}$"},
    "baseline_commit": {"$ref": "#/$defs/gitSha"},
    "build_contract_sha256": {"$ref": "#/$defs/sha256"},
    "bundle_hashes": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "build-contract.yaml",
        "repository-fingerprint.json",
        "production-fingerprint.json",
        "implementation.diff",
        "changed-files.txt",
        "test-results.json",
        "migration-plan.yaml",
        "security-impact.yaml",
        "rollback-plan.yaml",
        "known-risks.yaml"
      ],
      "properties": {
        "build-contract.yaml": {"$ref": "#/$defs/sha256"},
        "repository-fingerprint.json": {"$ref": "#/$defs/sha256"},
        "production-fingerprint.json": {"$ref": "#/$defs/sha256"},
        "implementation.diff": {"$ref": "#/$defs/sha256"},
        "changed-files.txt": {"$ref": "#/$defs/sha256"},
        "test-results.json": {"$ref": "#/$defs/sha256"},
        "migration-plan.yaml": {"$ref": "#/$defs/sha256"},
        "security-impact.yaml": {"$ref": "#/$defs/sha256"},
        "rollback-plan.yaml": {"$ref": "#/$defs/sha256"},
        "known-risks.yaml": {"$ref": "#/$defs/sha256"}
      }
    },
    "prepared_at": {"$ref": "#/$defs/timestamp"},
    "production_query_performed": {"const": false},
    "production_mutation_performed": {"const": false},
    "api_fallback_used": {"const": false},
    "claude_invocations": {"type": "integer", "minimum": 0, "maximum": 3},
    "contract_audit": {"$ref": "#/$defs/contractAudit"},
    "implementation": {"$ref": "#/$defs/implementation"},
    "remediation_captures": {
      "type": "array",
      "maxItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["replaced_at", "after_diff_audit_iteration", "diff_sha256", "test_status"],
        "properties": {
          "replaced_at": {"$ref": "#/$defs/timestamp"},
          "after_diff_audit_iteration": {"const": 1},
          "diff_sha256": {"$ref": "#/$defs/sha256"},
          "test_status": {"const": "PASS"}
        }
      }
    },
    "tests": {"$ref": "#/$defs/tests"},
    "diff_audits": {
      "type": "array",
      "maxItems": 2,
      "items": {"$ref": "#/$defs/diffAudit"}
    },
    "diff_audit_blocker": {"$ref": "#/$defs/externalBlocker"},
    "draft_pr": {"$ref": "#/$defs/draftPr"},
    "ready_for_draft_pr": {"type": "boolean"},
    "draft_pr_body_sha256": {"$ref": "#/$defs/sha256"}
  },
  "$defs": {
    "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "gitSha": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
    "timestamp": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}Z$"
    },
    "process": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "returncode",
        "stdout_sha256",
        "stderr_sha256",
        "stdout_bytes",
        "stderr_bytes",
        "raw_output_persisted"
      ],
      "properties": {
        "returncode": {"type": "integer"},
        "stdout_sha256": {"$ref": "#/$defs/sha256"},
        "stderr_sha256": {"$ref": "#/$defs/sha256"},
        "stdout_bytes": {"type": "integer", "minimum": 0},
        "stderr_bytes": {"type": "integer", "minimum": 0},
        "raw_output_persisted": {"const": false}
      }
    },
    "contractAudit": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["status"],
          "properties": {"status": {"const": "NOT_RUN"}}
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["status", "recorded_at", "reason"],
          "properties": {
            "status": {"const": "BLOCKED_EXTERNAL"},
            "recorded_at": {"$ref": "#/$defs/timestamp"},
            "reason": {"type": "string", "minLength": 1, "maxLength": 1000}
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["status", "recorded_at", "process", "response_sha256"],
          "properties": {
            "status": {"enum": ["APPROVED", "BLOCKED", "PAUSED_LIMIT_REACHED"]},
            "recorded_at": {"$ref": "#/$defs/timestamp"},
            "process": {"$ref": "#/$defs/process"},
            "response_sha256": {"$ref": "#/$defs/sha256"}
          }
        }
      ]
    },
    "implementation": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["status"],
          "properties": {"status": {"const": "NOT_CAPTURED"}}
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "status",
            "captured_at",
            "changed_files",
            "changed_file_count",
            "diff_bytes",
            "diff_sha256"
          ],
          "properties": {
            "status": {"const": "CAPTURED"},
            "captured_at": {"$ref": "#/$defs/timestamp"},
            "changed_files": {
              "type": "array",
              "minItems": 1,
              "maxItems": 200,
              "uniqueItems": true,
              "items": {"type": "string", "minLength": 1, "maxLength": 240}
            },
            "changed_file_count": {"type": "integer", "minimum": 1, "maximum": 200},
            "diff_bytes": {"type": "integer", "minimum": 1, "maximum": 2097152},
            "diff_sha256": {"$ref": "#/$defs/sha256"}
          }
        }
      ]
    },
    "tests": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["status"],
          "properties": {"status": {"const": "NOT_RUN"}}
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["status", "results_sha256"],
          "properties": {
            "status": {"enum": ["PASS", "FAIL"]},
            "results_sha256": {"$ref": "#/$defs/sha256"}
          }
        }
      ]
    },
    "diffAudit": {
      "type": "object",
      "additionalProperties": false,
      "required": ["iteration", "verdict", "recorded_at", "process", "response_sha256"],
      "properties": {
        "iteration": {"type": "integer", "minimum": 1, "maximum": 2},
        "verdict": {"enum": ["PASS", "BLOCK", "LIMIT_REACHED"]},
        "recorded_at": {"$ref": "#/$defs/timestamp"},
        "process": {"$ref": "#/$defs/process"},
        "response_sha256": {"$ref": "#/$defs/sha256"}
      }
    },
    "externalBlocker": {
      "type": "object",
      "additionalProperties": false,
      "required": ["iteration", "status", "recorded_at", "reason"],
      "properties": {
        "iteration": {"type": "integer", "minimum": 1, "maximum": 2},
        "status": {"const": "BLOCKED_EXTERNAL"},
        "recorded_at": {"$ref": "#/$defs/timestamp"},
        "reason": {"type": "string", "minLength": 1, "maxLength": 1000}
      }
    },
    "draftPr": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["status"],
          "properties": {"status": {"const": "NOT_RUN"}}
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "status",
            "recorded_at",
            "stdout_sha256",
            "raw_output_persisted",
            "auto_merge_performed",
            "deploy_performed"
          ],
          "properties": {
            "status": {"const": "CREATED_DRAFT"},
            "recorded_at": {"$ref": "#/$defs/timestamp"},
            "stdout_sha256": {"$ref": "#/$defs/sha256"},
            "raw_output_persisted": {"const": false},
            "auto_merge_performed": {"const": false},
            "deploy_performed": {"const": false}
          }
        }
      ]
    }
  }
}
