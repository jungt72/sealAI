{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sealingai.local/schemas/legacy-inventory-input.schema.json",
  "title": "Sanitized local legacy inventory input",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "inventory_id", "source", "objects"],
  "properties": {
    "schema_version": {"const": 1},
    "inventory_id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9._-]{2,63}$"
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "captured_at", "production_query_performed", "mutation_performed", "contains_secret_values"],
      "properties": {
        "kind": {"const": "SANITIZED_LOCAL_FIXTURE"},
        "captured_at": {
          "type": "string",
          "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}Z$"
        },
        "production_query_performed": {"const": false},
        "mutation_performed": {"const": false},
        "contains_secret_values": {"const": false}
      }
    },
    "objects": {
      "type": "array",
      "minItems": 13,
      "maxItems": 10000,
      "items": {"$ref": "#/$defs/object"}
    }
  },
  "$defs": {
    "object": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "asset_type",
        "lifecycle",
        "evidence_state",
        "dependencies",
        "owner",
        "backup",
        "dependency_evidence_complete",
        "rollback",
        "approval",
        "candidate_action",
        "notes"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9._:-]{1,127}$"
        },
        "asset_type": {
          "enum": [
            "container",
            "image",
            "service",
            "frontend",
            "feature_flag",
            "prompt_family",
            "qdrant_collection",
            "volume",
            "pm2_process",
            "network_workload",
            "configuration",
            "backup",
            "port"
          ]
        },
        "lifecycle": {"enum": ["ACTIVE", "LEGACY", "INACTIVE", "UNKNOWN"]},
        "evidence_state": {"enum": ["COMPLETE", "INCOMPLETE", "CONFLICTING"]},
        "dependencies": {
          "type": "array",
          "maxItems": 128,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9._:-]{1,127}$"
          }
        },
        "owner": {
          "type": "object",
          "additionalProperties": false,
          "required": ["known", "in_use"],
          "properties": {
            "known": {"type": "boolean"},
            "in_use": {"type": "boolean"}
          }
        },
        "backup": {
          "type": "object",
          "additionalProperties": false,
          "required": ["required", "available", "verified"],
          "properties": {
            "required": {"type": "boolean"},
            "available": {"type": "boolean"},
            "verified": {"type": "boolean"}
          }
        },
        "dependency_evidence_complete": {"type": "boolean"},
        "rollback": {
          "type": "object",
          "additionalProperties": false,
          "required": ["required", "documented", "tested"],
          "properties": {
            "required": {"type": "boolean"},
            "documented": {"type": "boolean"},
            "tested": {"type": "boolean"}
          }
        },
        "approval": {
          "type": "object",
          "additionalProperties": false,
          "required": ["required", "status"],
          "properties": {
            "required": {"type": "boolean"},
            "status": {"enum": ["NOT_REQUIRED", "NOT_REQUESTED", "PENDING", "APPROVED"]}
          }
        },
        "candidate_action": {"enum": ["NONE", "ARCHIVE", "DELETE"]},
        "notes": {
          "type": "array",
          "maxItems": 16,
          "items": {"type": "string", "minLength": 1, "maxLength": 500}
        }
      }
    }
  }
}
