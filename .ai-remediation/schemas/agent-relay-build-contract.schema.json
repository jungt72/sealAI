{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sealingai.local/schemas/agent-relay-build-contract.schema.json",
  "title": "sealingAI fail-closed agent relay build contract",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "contract_id",
    "run_id",
    "objective",
    "repository",
    "prerequisites",
    "claude_audits",
    "limits",
    "deterministic_tests",
    "migration_plan",
    "security_impact",
    "rollback_plan",
    "known_risks",
    "draft_pr"
  ],
  "properties": {
    "schema_version": {"const": 1},
    "contract_id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9._-]{2,63}$"
    },
    "run_id": {
      "type": "string",
      "pattern": "^[A-Z0-9][A-Z0-9._-]{2,63}$"
    },
    "objective": {"type": "string", "minLength": 16, "maxLength": 2000},
    "repository": {
      "type": "object",
      "additionalProperties": false,
      "required": ["expected_base_commit", "base_branch", "allowed_paths"],
      "properties": {
        "expected_base_commit": {
          "type": "string",
          "pattern": "^[0-9a-f]{40}$"
        },
        "base_branch": {
          "type": "string",
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._/-]{0,127}$"
        },
        "allowed_paths": {
          "type": "array",
          "minItems": 1,
          "maxItems": 64,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$))(?!.*[\\r\\n\\u0000]).{1,240}$"
          }
        }
      }
    },
    "prerequisites": {
      "type": "object",
      "additionalProperties": false,
      "required": ["release_freeze_respected", "production_mutation_authorized", "required_local_packages"],
      "properties": {
        "release_freeze_respected": {"const": true},
        "production_mutation_authorized": {"const": false},
        "required_local_packages": {
          "type": "array",
          "maxItems": 32,
          "uniqueItems": true,
          "items": {"type": "string", "minLength": 1, "maxLength": 80}
        }
      }
    },
    "claude_audits": {
      "type": "object",
      "additionalProperties": false,
      "required": ["model", "allowed_tools", "disallowed_tools", "max_turns", "max_budget_usd", "max_review_loops", "api_fallback_allowed"],
      "properties": {
        "model": {
          "type": "string",
          "pattern": "^claude-(?!.*opus)[a-z0-9.-]{4,80}$"
        },
        "allowed_tools": {
          "const": []
        },
        "disallowed_tools": {
          "type": "array",
          "allOf": [
            {"contains": {"const": "Write"}},
            {"contains": {"const": "Edit"}},
            {"contains": {"const": "Bash"}},
            {"contains": {"const": "WebFetch"}},
            {"contains": {"const": "WebSearch"}}
          ],
          "uniqueItems": true,
          "items": {"type": "string", "minLength": 1, "maxLength": 40}
        },
        "max_turns": {"type": "integer", "minimum": 1, "maximum": 8},
        "max_budget_usd": {"type": "number", "exclusiveMinimum": 0, "maximum": 0.75},
        "max_review_loops": {"const": 2},
        "api_fallback_allowed": {"const": false}
      }
    },
    "limits": {
      "type": "object",
      "additionalProperties": false,
      "required": ["max_changed_files", "max_diff_bytes", "max_input_bytes", "max_test_seconds", "max_process_output_bytes"],
      "properties": {
        "max_changed_files": {"type": "integer", "minimum": 1, "maximum": 200},
        "max_diff_bytes": {"type": "integer", "minimum": 1024, "maximum": 2097152},
        "max_input_bytes": {"type": "integer", "minimum": 1024, "maximum": 1048576},
        "max_test_seconds": {"type": "integer", "minimum": 1, "maximum": 1800},
        "max_process_output_bytes": {"type": "integer", "minimum": 1024, "maximum": 1048576}
      }
    },
    "deterministic_tests": {
      "type": "array",
      "minItems": 1,
      "maxItems": 8,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "argv"],
        "properties": {
          "name": {"type": "string", "pattern": "^[a-z0-9][a-z0-9._-]{1,63}$"},
          "argv": {
            "type": "array",
            "minItems": 2,
            "maxItems": 40,
            "items": {
              "type": "string",
              "minLength": 1,
              "maxLength": 300,
              "pattern": "^[^\\r\\n\\u0000]+$"
            }
          }
        }
      }
    },
    "migration_plan": {"$ref": "#/$defs/plan"},
    "security_impact": {"$ref": "#/$defs/plan"},
    "rollback_plan": {"$ref": "#/$defs/plan"},
    "known_risks": {"$ref": "#/$defs/plan"},
    "draft_pr": {
      "type": "object",
      "additionalProperties": false,
      "required": ["title", "body_file", "auto_merge", "auto_deploy"],
      "properties": {
        "title": {"type": "string", "minLength": 8, "maxLength": 120},
        "body_file": {
          "type": "string",
          "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$))(?!.*[\\r\\n\\u0000]).{1,240}$"
        },
        "auto_merge": {"const": false},
        "auto_deploy": {"const": false}
      }
    }
  },
  "$defs": {
    "plan": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "items"],
      "properties": {
        "status": {"enum": ["NOT_APPLICABLE", "PLANNED", "REQUIRED"]},
        "items": {
          "type": "array",
          "minItems": 1,
          "maxItems": 32,
          "items": {"type": "string", "minLength": 3, "maxLength": 500}
        }
      }
    }
  }
}
