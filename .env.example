# .env (angepasst)

#########################################
# 🔐 OpenAI (für RAG & ChatGPT)
#########################################
OPENAI_API_KEY=<REPLACE_ME>
OPENAI_MODEL=<REPLACE_ME>

#########################################
# 🐘 PostgreSQL (Backend-DB & Chat-Verläufe)
#########################################
POSTGRES_USER=<REPLACE_ME>
POSTGRES_PASSWORD=<REPLACE_ME>
POSTGRES_HOST=<REPLACE_ME>
POSTGRES_PORT=<REPLACE_ME>
POSTGRES_DB=<REPLACE_ME>
DATABASE_URL=<REPLACE_ME>

#########################################
# 🔐 Redis (Transiente Speicherung)
#########################################
REDIS_HOST=<REPLACE_ME>
REDIS_PORT=<REPLACE_ME>
REDIS_URL=<REPLACE_ME>
LANGGRAPH_CHECKPOINT_TTL=<SECONDS_E.G._604800>
# SSE replay backend (optional; default is in-memory)
# SEALAI_SSE_REPLAY_BACKEND=redis
# SEALAI_SSE_REPLAY_TTL_SEC=3600
# SEALAI_SSE_REPLAY_MAXLEN=500

#########################################
# 🧠 Qdrant (Vector-DB für RAG)
#########################################
QDRANT_URL=<REPLACE_ME>
QDRANT_COLLECTION=<REPLACE_ME>
RAG_K=<REPLACE_ME>

#########################################
# 🌐 NextAuth.js (Frontend Auth)
#########################################
NEXTAUTH_URL=<REPLACE_ME>
NEXTAUTH_SECRET=<REPLACE_ME>
KEYCLOAK_ISSUER=<REPLACE_ME>
KEYCLOAK_CLIENT_ID=<REPLACE_ME>
KEYCLOAK_CLIENT_SECRET=<REPLACE_ME>
KEYCLOAK_EXPECTED_AZP=<REPLACE_ME>

#########################################
# 🔐 Keycloak-OIDC (Backend Token-Validierung)
#########################################
BACKEND_KEYCLOAK_ISSUER=<REPLACE_ME>
KEYCLOAK_URL=<REPLACE_ME>
KEYCLOAK_JWKS_URL=<REPLACE_ME>
KEYCLOAK_CLIENT_ID=<REPLACE_ME>
KEYCLOAK_EXPECTED_AZP=<REPLACE_ME>

#########################################
# 🧠 Embedding-Modell für RAG
#########################################
EMBEDDING_MODEL=<REPLACE_ME>

#########################################
# 🔍 LangSmith / LangChain Tracing
#########################################
LANGCHAIN_TRACING_V2=<REPLACE_ME>
LANGCHAIN_ENDPOINT=<REPLACE_ME>
LANGCHAIN_API_KEY=<REPLACE_ME>
LANGCHAIN_PROJECT=<REPLACE_ME>

#########################################
# 🛠 Debug-Flags
#########################################
DEBUG_SQL=<REPLACE_ME>
DEBUG_QDRANT=<REPLACE_ME>
NEXT_PUBLIC_BASE_URL=<REPLACE_ME>
