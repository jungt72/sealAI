# ============================================================
# SealAI — Environment Template  (Phase H)
# ============================================================
# Copy to .env (dev) or .env.prod (production) and fill in
# every CHANGE_ME before starting the stack.
#
# REQUIRED = docker-compose fails with :? error if unset
# OPTIONAL = has a sensible default in docker-compose.yml
#
# Dev startup:   docker compose up -d
# Prod startup:  docker compose -f docker-compose.yml \
#                               -f docker-compose.deploy.yml \
#                               --env-file .env.prod up -d
#
# NEVER commit .env or .env.prod to version control.
# ============================================================

# ── Docker Images (production only) ────────────────────────
# Pin to immutable digests.  Update after every CI push.
BACKEND_IMAGE=ghcr.io/jungt72/sealai-backend:TAG@sha256:CHANGE_ME
BACKEND_PULL_POLICY=always
KEYCLOAK_IMAGE=ghcr.io/jungt72/sealai-keycloak:TAG@sha256:CHANGE_ME
FRONTEND_IMAGE=ghcr.io/jungt72/sealai-frontend@sha256:CHANGE_ME   # profile: frontend-container
BACKEND_V2_IMAGE=ghcr.io/jungt72/sealai-backend-v2:TAG@sha256:REPLACE_WITH_64_HEX_DIGEST
NGINX_IMAGE=docker.io/library/nginx:TAG@sha256:REPLACE_WITH_64_HEX_DIGEST
POSTGRES_IMAGE=docker.io/library/postgres:TAG@sha256:REPLACE_WITH_64_HEX_DIGEST
REDIS_IMAGE=docker.io/redis/redis-stack-server:TAG@sha256:REPLACE_WITH_64_HEX_DIGEST
QDRANT_IMAGE=docker.io/qdrant/qdrant:TAG@sha256:REPLACE_WITH_64_HEX_DIGEST
GOTENBERG_IMAGE=docker.io/gotenberg/gotenberg:TAG@sha256:REPLACE_WITH_64_HEX_DIGEST
TIKA_IMAGE=docker.io/apache/tika:TAG@sha256:REPLACE_WITH_64_HEX_DIGEST
ALERTMANAGER_IMAGE=docker.io/prom/alertmanager:TAG@sha256:REPLACE_WITH_64_HEX_DIGEST
BLACKBOX_EXPORTER_IMAGE=docker.io/prom/blackbox-exporter:TAG@sha256:REPLACE_WITH_64_HEX_DIGEST
NODE_EXPORTER_IMAGE=docker.io/prom/node-exporter:TAG@sha256:REPLACE_WITH_64_HEX_DIGEST
CADVISOR_IMAGE=gcr.io/cadvisor/cadvisor:TAG@sha256:REPLACE_WITH_64_HEX_DIGEST
POSTGRES_EXPORTER_IMAGE=quay.io/prometheuscommunity/postgres-exporter:TAG@sha256:REPLACE_WITH_64_HEX_DIGEST
REDIS_EXPORTER_IMAGE=docker.io/oliver006/redis_exporter:TAG@sha256:REPLACE_WITH_64_HEX_DIGEST

# Required but intentionally unset until the Gate-08 bounded-load rehearsal.
# Use Compose-compatible values (for example bytes/"m"/"g" for memory and a
# positive decimal for CPUs); do not guess these values in production.
POSTGRES_MEMORY_LIMIT=<SET_FROM_LOAD_PROFILE>
POSTGRES_CPU_LIMIT=<SET_FROM_LOAD_PROFILE>
POSTGRES_PIDS_LIMIT=<SET_FROM_LOAD_PROFILE>
REDIS_MEMORY_LIMIT=<SET_FROM_LOAD_PROFILE>
REDIS_CPU_LIMIT=<SET_FROM_LOAD_PROFILE>
REDIS_PIDS_LIMIT=<SET_FROM_LOAD_PROFILE>
QDRANT_MEMORY_LIMIT=<SET_FROM_LOAD_PROFILE>
QDRANT_CPU_LIMIT=<SET_FROM_LOAD_PROFILE>
QDRANT_PIDS_LIMIT=<SET_FROM_LOAD_PROFILE>
GOTENBERG_MEMORY_LIMIT=<SET_FROM_LOAD_PROFILE>
GOTENBERG_CPU_LIMIT=<SET_FROM_LOAD_PROFILE>
GOTENBERG_PIDS_LIMIT=<SET_FROM_LOAD_PROFILE>
TIKA_MEMORY_LIMIT=<SET_FROM_LOAD_PROFILE>
TIKA_CPU_LIMIT=<SET_FROM_LOAD_PROFILE>
TIKA_PIDS_LIMIT=<SET_FROM_LOAD_PROFILE>
PROMETHEUS_MEMORY_LIMIT=<SET_FROM_LOAD_PROFILE>
PROMETHEUS_CPU_LIMIT=<SET_FROM_LOAD_PROFILE>
PROMETHEUS_PIDS_LIMIT=<SET_FROM_LOAD_PROFILE>
GRAFANA_MEMORY_LIMIT=<SET_FROM_LOAD_PROFILE>
GRAFANA_CPU_LIMIT=<SET_FROM_LOAD_PROFILE>
GRAFANA_PIDS_LIMIT=<SET_FROM_LOAD_PROFILE>
ALERTMANAGER_MEMORY_LIMIT=<SET_FROM_LOAD_PROFILE>
ALERTMANAGER_CPU_LIMIT=<SET_FROM_LOAD_PROFILE>
ALERTMANAGER_PIDS_LIMIT=<SET_FROM_LOAD_PROFILE>
BLACKBOX_EXPORTER_MEMORY_LIMIT=<SET_FROM_LOAD_PROFILE>
BLACKBOX_EXPORTER_CPU_LIMIT=<SET_FROM_LOAD_PROFILE>
BLACKBOX_EXPORTER_PIDS_LIMIT=<SET_FROM_LOAD_PROFILE>
NODE_EXPORTER_MEMORY_LIMIT=<SET_FROM_LOAD_PROFILE>
NODE_EXPORTER_CPU_LIMIT=<SET_FROM_LOAD_PROFILE>
NODE_EXPORTER_PIDS_LIMIT=<SET_FROM_LOAD_PROFILE>
CADVISOR_MEMORY_LIMIT=<SET_FROM_LOAD_PROFILE>
CADVISOR_CPU_LIMIT=<SET_FROM_LOAD_PROFILE>
CADVISOR_PIDS_LIMIT=<SET_FROM_LOAD_PROFILE>
POSTGRES_EXPORTER_MEMORY_LIMIT=<SET_FROM_LOAD_PROFILE>
POSTGRES_EXPORTER_CPU_LIMIT=<SET_FROM_LOAD_PROFILE>
POSTGRES_EXPORTER_PIDS_LIMIT=<SET_FROM_LOAD_PROFILE>
REDIS_EXPORTER_MEMORY_LIMIT=<SET_FROM_LOAD_PROFILE>
REDIS_EXPORTER_CPU_LIMIT=<SET_FROM_LOAD_PROFILE>
REDIS_EXPORTER_PIDS_LIMIT=<SET_FROM_LOAD_PROFILE>
GRAFANA_ADMIN_PASSWORD=<REPLACE_WITH_ROTATED_GRAFANA_ADMIN_PASSWORD>
FRONTEND_MEMORY_LIMIT=<SET_FROM_LOAD_PROFILE>
FRONTEND_CPU_LIMIT=<SET_FROM_LOAD_PROFILE>
FRONTEND_PIDS_LIMIT=<SET_FROM_LOAD_PROFILE>
KEYCLOAK_MEMORY_LIMIT=<SET_FROM_LOAD_PROFILE>
KEYCLOAK_CPU_LIMIT=<SET_FROM_LOAD_PROFILE>
KEYCLOAK_PIDS_LIMIT=<SET_FROM_LOAD_PROFILE>
NGINX_MEMORY_LIMIT=<SET_FROM_LOAD_PROFILE>
NGINX_CPU_LIMIT=<SET_FROM_LOAD_PROFILE>
NGINX_PIDS_LIMIT=<SET_FROM_LOAD_PROFILE>
BACKEND_V2_MEMORY_LIMIT=<SET_FROM_LOAD_PROFILE>
BACKEND_V2_CPU_LIMIT=<SET_FROM_LOAD_PROFILE>
BACKEND_V2_PIDS_LIMIT=<SET_FROM_LOAD_PROFILE>
BACKEND_V2_WORKER_MEMORY_LIMIT=<SET_FROM_LOAD_PROFILE>
BACKEND_V2_WORKER_CPU_LIMIT=<SET_FROM_LOAD_PROFILE>
BACKEND_V2_WORKER_PIDS_LIMIT=<SET_FROM_LOAD_PROFILE>
CONTAINER_LOG_MAX_SIZE=10m
CONTAINER_LOG_MAX_FILES=5

# Gate-05 creates this one scoped cross-project bridge. The old
# `sealai_default` network is forbidden for biz/paperless/staging workloads.
STRAPI_POSTGRES_NETWORK_NAME=<SET_DURING_GATE_05>
STRAPI_IMAGE=registry.example.invalid/sealai-strapi:TAG@sha256:REPLACE_WITH_64_HEX_DIGEST
ODOO_IMAGE=docker.io/library/odoo:TAG@sha256:REPLACE_WITH_64_HEX_DIGEST
ODOO_POSTGRES_IMAGE=docker.io/library/postgres:TAG@sha256:REPLACE_WITH_64_HEX_DIGEST
ODOO_DB_PASSWORD=<REPLACE_WITH_ROTATED_ODOO_DB_PASSWORD>

# ── PostgreSQL ─────────────────────────────────────────────
POSTGRES_USER=sealai                              # OPTIONAL  default: sealai
POSTGRES_PASSWORD=<REPLACE_WITH_LOCAL_POSTGRES_PASSWORD>
POSTGRES_HOST=postgres                            # OPTIONAL  default: postgres
POSTGRES_PORT=5432                                # OPTIONAL  default: 5432
POSTGRES_DB=sealai                                # OPTIONAL  default: sealai
# Full DSNs (computed from above if omitted)
DATABASE_URL=postgresql+asyncpg://sealai:CHANGE_ME@postgres:5432/sealai
POSTGRES_SYNC_URL=postgresql+psycopg2://sealai:CHANGE_ME@postgres:5432/sealai
POSTGRES_DSN=postgresql://sealai:CHANGE_ME@postgres:5432/sealai

# ── Redis ──────────────────────────────────────────────────
REDIS_PASSWORD=<REPLACE_WITH_LOCAL_REDIS_PASSWORD>
REDIS_MAXMEMORY=1024mb
REDIS_URL=redis://:CHANGE_ME@redis:6379/0         # used by backend pydantic settings
APP_ENV=development
SEALAI_LANGGRAPH_CHECKPOINTING=false
LANGGRAPH_V2_REDIS_URL=redis://:CHANGE_ME@redis:6379/0

# ── Qdrant ─────────────────────────────────────────────────
QDRANT_URL=http://qdrant:6333                     # OPTIONAL  default: http://qdrant:6333
QDRANT_COLLECTION=sealai_knowledge_v3             # REQUIRED
QDRANT_VECTOR_NAME=dense
QDRANT_API_KEY=<REPLACE_WITH_ROTATED_QDRANT_API_KEY>
QDRANT_READ_ONLY_API_KEY=<REPLACE_WITH_DISTINCT_QDRANT_READ_ONLY_API_KEY>
NODE_EXPORTER_TEXTFILE_DIR=/var/lib/sealai/node-exporter/textfile

# ── Keycloak container ─────────────────────────────────────
KC_DB_NAME=<REPLACE_WITH_DEDICATED_KEYCLOAK_DATABASE>
KC_DB_URL=jdbc:postgresql://postgres:5432/CHANGE_ME
KC_DB_USERNAME=<REPLACE_WITH_DEDICATED_KEYCLOAK_ROLE>
KC_DB_PASSWORD=<REPLACE_WITH_DEDICATED_KEYCLOAK_PASSWORD>
# Development bootstrap only. Never copy these keys into .env.prod.
KC_BOOTSTRAP_ADMIN_USERNAME=admin
KC_BOOTSTRAP_ADMIN_PASSWORD=<REPLACE_WITH_LOCAL_BOOTSTRAP_ADMIN_PASSWORD>

# ── Keycloak OIDC (backend + frontend) ─────────────────────
KEYCLOAK_REALM=sealAI
KEYCLOAK_SECURITY_PROFILE=test
KEYCLOAK_ISSUER=https://sealingai.com/realms/sealAI         # REQUIRED
KEYCLOAK_JWKS_URL=https://sealingai.com/realms/sealAI/protocol/openid-connect/certs  # REQUIRED
KEYCLOAK_CLIENT_ID=nextauth
KEYCLOAK_CLIENT_SECRET=<REPLACE_WITH_KEYCLOAK_CLIENT_SECRET>
KEYCLOAK_EXPECTED_AZP=nextauth
EXPECTED_AZP=nextauth                             # OPTIONAL  default: nextauth (compose alias)

# ── NextAuth / Auth.js ─────────────────────────────────────
NEXTAUTH_URL=https://sealingai.com
NEXTAUTH_SECRET=<REPLACE_WITH_NEXTAUTH_SECRET>
NEXTAUTH_DEBUG=false
AUTH_SECRET=<REPLACE_WITH_AUTH_SECRET>
AUTH_URL=https://sealingai.com
AUTH_TRUST_HOST=true
AUTH_DEBUG=0

# ── sealingAI V2 model and governed mode policy ────────────
OPENAI_API_KEY=<REPLACE_WITH_OPENAI_API_KEY>
MISTRAL_API_KEY=<REPLACE_WITH_MISTRAL_API_KEY>
SEALAI_V2_DB_USER=<REPLACE_WITH_DEDICATED_V2_ROLE>
SEALAI_V2_DB_PASSWORD=<REPLACE_WITH_DEDICATED_V2_PASSWORD>
SEALAI_V2_WORKER_DB_USER=<REPLACE_WITH_DISTINCT_V2_WORKER_ROLE>
SEALAI_V2_WORKER_DB_PASSWORD=<REPLACE_WITH_DISTINCT_V2_WORKER_PASSWORD>
SEALAI_V2_DATABASE_RLS_SCOPE_ENABLED=false
SEALAI_V2_PROVIDER=mistral
SEALAI_V2_L1_PROVIDER=openai
SEALAI_V2_L1_MODEL=gpt-5.5
SEALAI_V2_STANDARD_PROVIDER=mistral
SEALAI_V2_STANDARD_MODEL=mistral-small-2603
SEALAI_V2_VERIFIER_PROVIDER=mistral
SEALAI_V2_VERIFIER_MODEL=mistral-small-2603
SEALAI_V2_HELPER_PROVIDER=mistral
SEALAI_V2_HELPER_MODEL=mistral-small-2603
SEALAI_V2_EXECUTION_POLICY_ENABLED=true
SEALAI_V2_STRUCTURED_ANSWER_ENABLED=true
SEALAI_V2_KNOWLEDGE_MODE_ENABLED=false
SEALAI_V2_KNOWLEDGE_REVIEW_ENABLED=false
SEALAI_V2_COMPATIBILITY_MATRIX_ENABLED=false
SEALAI_V2_CASE_DECISION_RECORDS_ENABLED=false
SEALAI_V2_CAPABILITY_PROFILES_ENABLED=false
SEALAI_V2_MANUFACTURER_FIT_ENABLED=false
SEALAI_V2_MANUFACTURER_HANDOFF_ENABLED=false
SEALAI_V2_AUTH_CAPABILITY_REVIEWER_ROLE=capability_reviewer
SEALAI_V2_AUTH_KNOWLEDGE_REVIEWER_ROLE=knowledge_reviewer
SEALAI_V2_AUTH_DECISION_REVIEWER_ROLE=decision_reviewer

# Closed paid-provider baseline. Activation requires the reviewed contract digest and DB migration.
SEALAI_V2_AUTH_JWKS_TTL_S=300
SEALAI_V2_AUTH_JWKS_MAX_TTL_S=600
SEALAI_V2_AUTH_JWKS_UNKNOWN_KID_REFRESH_INTERVAL_S=5
SEALAI_V2_AUTH_JWKS_NEGATIVE_KID_TTL_S=30
SEALAI_V2_AUTH_JWKS_MAX_NEGATIVE_KIDS=256
SEALAI_V2_AUTH_MAX_TOKEN_AGE_S=300
SEALAI_V2_AUTH_CLOCK_SKEW_S=30
SEALAI_V2_PROVIDER_REQUESTS_ENABLED=false
SEALAI_V2_PROVIDER_SUBJECT_REQUESTS_PER_MINUTE=6
SEALAI_V2_PROVIDER_TENANT_REQUESTS_PER_MINUTE=30
SEALAI_V2_PROVIDER_SUBJECT_REQUESTS_PER_DAY=100
SEALAI_V2_PROVIDER_TENANT_REQUESTS_PER_DAY=1000
SEALAI_V2_PROVIDER_TENANT_REQUESTS_PER_MONTH=20000
SEALAI_V2_PROVIDER_SUBJECT_MAX_CONCURRENT=2
SEALAI_V2_PROVIDER_TENANT_MAX_CONCURRENT=10
SEALAI_V2_PROVIDER_REQUEST_LEASE_S=300
SEALAI_V2_PROVIDER_REQUEST_RESERVATION_MICROS=250000
SEALAI_V2_PROVIDER_DAILY_BUDGET_MICROS=10000000
SEALAI_V2_PROVIDER_MONTHLY_BUDGET_MICROS=100000000
SEALAI_V2_PROVIDER_BUDGET_CONTRACT_SHA256=
SEALAI_V2_API_MAX_REQUEST_BODY_BYTES=131072

# ── LangSmith Tracing (optional) ───────────────────────────
# Prefer LANGSMITH_*; LANGCHAIN_* names are kept for older LangChain integrations.
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=<REPLACE_WITH_LANGSMITH_API_KEY_OR_EMPTY>
LANGSMITH_PROJECT=sealai-production
LANGSMITH_ENDPOINT=
SEALAI_TRACE_HASH_SALT=<REPLACE_WITH_STABLE_SECRET_SALT>
LANGSMITH_CAPTURE_LLM_CONTENT=false
LANGSMITH_TRACE_LANGGRAPH_CHILDREN=false
# Leave tracing=false to disable — no API key needed.
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=<REPLACE_WITH_LANGCHAIN_API_KEY_OR_EMPTY>
LANGCHAIN_PROJECT=sealai-production
LANGCHAIN_ENDPOINT=

# ── Frontend / CORS ────────────────────────────────────────
NEXT_PUBLIC_API_BASE=https://sealingai.com
NEXT_PUBLIC_SITE_URL=https://sealingai.com
NEXT_PUBLIC_ANALYTICS_ENABLED=false
NEXT_PUBLIC_GTM_ID=
NEXT_PUBLIC_GA_MEASUREMENT_ID=
NEXT_PUBLIC_GOOGLE_CONSENT_DEFAULT=denied
NEXT_PUBLIC_RYBBIT_ENABLED=false
NEXT_PUBLIC_RYBBIT_SITE_ID=
NEXT_PUBLIC_RYBBIT_SCRIPT_SRC=https://analytics.sealingai.com/api/script.js
NEXT_PUBLIC_RYBBIT_DASHBOARD_URL=
FRONTEND_ORIGIN=https://sealingai.com
ALLOWED_ORIGIN=https://sealingai.com,https://www.sealingai.com      # REQUIRED  comma-separated
ALLOW_WS_ORIGIN_ANY=0
ALLOW_WS_ORIGIN_EMPTY=0
API_INTERNAL_BASE=http://backend:8000
SEALAI_BACKEND_ORIGIN=http://127.0.0.1:8000

# ── Paperless-ngx RAG integration ─────────────────────────
PAPERLESS_URL=http://paperless:8000
PAPERLESS_TOKEN=CHANGE_ME
PAPERLESS_WEBHOOK_TOKEN=CHANGE_ME

# ── RAG / Embeddings ───────────────────────────────────────
RAG_PROVIDER=fastembed
RAG_EMBEDDING_MODEL=BAAI/bge-base-en-v1.5
RAG_EMBEDDING_DIM=768
EMBEDDING_BACKEND=fastembed
FASTEMBED_MODEL=BAAI/bge-base-en-v1.5
FASTEMBED_CACHE_PATH=/tmp/fastembed_cache
RAG_TOP_K=6
RAG_SCORE_THRESHOLD=0.25
RAG_DENSE_MODEL=BAAI/bge-base-en-v1.5
RAG_SPARSE_ENABLED=1
RAG_SHARED_TENANT_ENABLED=1
RAG_SHARED_TENANT_ID=sealai

# ── LangGraph checkpointing ────────────────────────────────
LANGGRAPH_CHECKPOINT_PREFIX=lg:cp
LANGGRAPH_CHECKPOINT_NS=consult.v1
LANGGRAPH_CHECKPOINT_TTL=86400
LANGGRAPH_V2_CHECKPOINTER_TTL_SECONDS=86400
LANGGRAPH_V2_TTL_ENFORCER_ENABLED=1
LANGGRAPH_V2_TTL_ENFORCER_INTERVAL_SECONDS=300

# ── Debug / Observability ──────────────────────────────────
SEALAI_LOG_LEVEL=INFO
SEALAI_SSE_DEBUG=0
NEXT_PUBLIC_PARAM_SYNC_DEBUG=0
