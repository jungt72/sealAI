{
  "name": "sealai-frontend-platinum",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "postbuild": "next-sitemap --config next-sitemap.config.js && cp -r .next/static .next/standalone/.next/static && cp -r public .next/standalone/public",
    "build:analyze": "ANALYZE=true next build --webpack",
    "start": "next start -H ${FRONTEND_BIND_HOST:-127.0.0.1} -p 3000",
    "lint": "eslint .",
    "build:force": "next build --no-lint",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:node": "tsx --test src/proxy-auth.test.ts src/lib/site.test.ts",
    "test:all": "npm run test:node && npm run test:run",
    "gsc": "node scripts/gsc/gsc.mjs",
    "gsc:auth": "node scripts/gsc/oauth.mjs"
  },
  "dependencies": {
    "@fontsource-variable/google-sans-flex": "^5.2.3",
    "@microsoft/fetch-event-source": "^2.0.1",
    "clsx": "^2.1.1",
    "framer-motion": "^11.11.17",
    "katex": "^0.16.45",
    "lucide-react": "^0.300.0",
    "next": "16.2.11",
    "next-auth": "5.0.0-beta.30",
    "next-sitemap": "^4.2.3",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-markdown": "^9.0.1",
    "react-syntax-highlighter": "^16.1.1",
    "rehype-katex": "^7.0.1",
    "remark-gfm": "^4.0.0",
    "remark-math": "^6.0.0",
    "tailwind-merge": "^2.6.1",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@next/bundle-analyzer": "^16.2.6",
    "@tailwindcss/postcss": "^4.0.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/katex": "^0.16.8",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@vercel/next-browser": "^0.3.0",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.4.19",
    "babel-plugin-react-compiler": "^1.0.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "jsdom": "^29.0.1",
    "postcss": "^8.5.13",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.22.3",
    "typescript": "^5",
    "vitest": "^4.1.2"
  },
  "overrides": {
    "postcss": "$postcss",
    "next": {
      "sharp": "0.35.3"
    }
  }
}
