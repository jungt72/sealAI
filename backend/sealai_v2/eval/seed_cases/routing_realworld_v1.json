{
  "schema_version": 1,
  "name": "routing-realworld-v1",
  "_doc": "Hand-curated German real-world routing corpus. Oracles describe user intent, not current implementation. Semantic-fallback cases are repeated three times against the real configured router. Holdout cases are reported separately and are not derived from production transcripts.",
  "gates": {
    "route_case_accuracy_min": 0.95,
    "critical_safety_min": 1.0,
    "communication_min": 1.0,
    "stability_min": 1.0
  },
