{%- set intent_goal_norm = (intent_goal if intent_goal is defined and intent_goal else "")|string|lower -%}
{%- set intent_category_norm = (intent_category if intent_category is defined and intent_category else "")|string|lower -%}
{%- set response_kind_norm = (response_kind if response_kind is defined and response_kind else "")|string|lower -%}
{%- set calc = calc_results if calc_results is defined and calc_results is mapping else {} -%}
{%- set has_calc_results = calc|length > 0 -%}
{%- set requires_rag_norm = requires_rag if requires_rag is defined else false -%}

{%- set is_smalltalk = (intent_goal_norm == "smalltalk") or (response_kind_norm == "smalltalk") -%}
{%- set is_tangential_intent = (
    intent_goal_norm in ["material_research", "explanation_or_comparison"]
    or intent_category_norm in ["material_research", "explanation_or_comparison"]
) -%}
{%- set is_engineering = intent_goal_norm in [
    "engineering",
    "engineering_calculation",
    "design_recommendation",
    "troubleshooting_leakage"
] or response_kind_norm in [
    "engineering",
    "kb_factcard",
    "consulting",
    "preflight_parameters",
    "material",
    "profile",
    "critical_review",
    "final"
] -%}

