ENV=production
LOG_LEVEL=INFO
LLM_MODEL_DEFAULT=gpt-5-mini
REDIS_URL=redis://redis:6379/0
REDIS_CHECKPOINTER_URL=redis://redis:6379/0
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION_PREFIX=sealai-docs
LTM_COLLECTION=sealai_ltm
LTM_EMB_MODEL=intfloat/multilingual-e5-base

# External agent microservices
# Normen-Agent base URL (used as RAG fallback if no vector hits)
AGENT_NORMEN_URL=http://normen-agent:9101
# Material-Agent base URL (additional fallback)
AGENT_MATERIAL_URL=http://material-agent:9102
