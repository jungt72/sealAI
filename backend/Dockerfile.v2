# =============================================================================
# Dockerfile.v2 — the green-field sealai_v2 image (cutover Phase 1: full /api/v2 app).
#
# Single-stage slim image serving sealai_v2.api.main:app on port 8001: /health,
# /api/v2/{chat,conversations,briefing,framing,health}. No `app` (V1) code — the
# green-field boundary holds at the image level too. Production Compose accepts
# only a digest-pinned published backend-v2 image; this Dockerfile is built by
# the credential-free OCI-evidence workflow, never as a production fallback.
#
# Build context is ./backend (same as the production image), so `COPY sealai_v2`
# resolves to backend/sealai_v2.
# =============================================================================
FROM python:3.12-slim@sha256:c3d81d25b3154142b0b42eb1e61300024426268edeb5b5a26dd7ddf64d9daf28

ENV PYTHONUNBUFFERED=1 \
    PIP_DISABLE_PIP_VERSION_CHECK=1 \
    PIP_NO_CACHE_DIR=1 \
    DEBIAN_FRONTEND=noninteractive
WORKDIR /app

# Non-root user (matches the production image's uid).
RUN useradd -m -u 10001 -s /usr/sbin/nologin appuser

# The direct manifest is reviewable; the generated transitive lock is the only
# install input. --require-hashes makes missing or substituted distributions a
# hard build failure.
COPY requirements-v2.txt requirements-v2.lock ./
RUN python -m pip install --require-hashes -r requirements-v2.lock

# Green-field package only — never the `app` tree.
COPY sealai_v2 ./sealai_v2

# Import keystone: fail the BUILD (not the first request) if a dep is missing — including the
# lazy I/O-edge imports (openai SDK, httpx JWKS fetch).
RUN python -c "import alembic, httpx, psycopg2, sqlalchemy; from openai import AsyncOpenAI; import sealai_v2.api.main, sealai_v2.db.migrate"

RUN chown -R appuser:appuser /app

# V2 deploy teeth — the entrypoint refuses to start an UNGATED build (empty marker).
# ops/release-backend-v2.sh passes --build-arg GATE_TREE_HASH=<served tree_hash> for
# both candidate and final stages; a raw
# `docker compose build backend-v2` leaves it empty → build-identity validation rejects the build.
# The entrypoint verifies the same identity again at startup. Placed late so the per-build identity
# never busts the dependency/COPY layers above.
COPY docker-entrypoint-v2.sh /usr/local/bin/docker-entrypoint-v2.sh
RUN chmod +x /usr/local/bin/docker-entrypoint-v2.sh
ARG GATE_TREE_HASH=""
ARG SOURCE_GIT_SHA=""
RUN mkdir -p /etc/sealai \
 && printf '%s' "${GATE_TREE_HASH}" > /etc/sealai/gate-tree-hash \
 && python -m sealai_v2.config.build_identity write \
      --tree-hash "${GATE_TREE_HASH}" \
      --git-sha "${SOURCE_GIT_SHA}" \
      --requirements-file /app/requirements-v2.lock \
      --output /etc/sealai/release-identity.json

LABEL org.opencontainers.image.revision="${SOURCE_GIT_SHA}" \
      io.sealai.served-tree-hash="${GATE_TREE_HASH}"

USER appuser

EXPOSE 8001

HEALTHCHECK --interval=30s --timeout=10s --start-period=10s --retries=3 \
  CMD python -c "import urllib.request; urllib.request.urlopen('http://127.0.0.1:8001/health', timeout=5).read()" || exit 1

ENTRYPOINT ["/usr/local/bin/docker-entrypoint-v2.sh"]
CMD ["uvicorn", "sealai_v2.api.main:app", "--host", "0.0.0.0", "--port", "8001"]
